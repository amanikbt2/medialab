      function getWorkspaceIndex() {
        const root = ensureBuilderProjectFiles();
        const output = [];
        const walk = (node, currentPath = "") => {
          if (!node) return;
          if (node.type === "file") {
            output.push(normalizeBuilderFilePath(currentPath));
            return;
          }
          const children = Array.isArray(node.children) ? node.children : [];
          children.forEach((child) => {
            const childPath = normalizeBuilderFilePath(
              currentPath ? `${currentPath}/${child.name}` : child.name,
            );
            walk(child, childPath);
          });
        };
        (Array.isArray(root.children) ? root.children : []).forEach((child) =>
          walk(child, child.name),
        );
