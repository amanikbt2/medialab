        const chars = raw.length;
        const readingTime = words ? Math.max(1, Math.ceil(words / 220)) : 0;
        const wordCount = document.getElementById("word-count");
        const charCount = document.getElementById("char-count");
        const reading = document.getElementById("reading-time");
        const readingLabel = document.getElementById("editor-reading-label");
        const status = document.getElementById("word-processor-status");
        if (wordCount) wordCount.textContent = `${words} Words`;
        if (charCount) charCount.textContent = `${chars} Chars`;
        if (reading) reading.textContent = `${readingTime} Min Read`;
        if (readingLabel) readingLabel.textContent = `${readingTime} min read`;
        if (status)
          status.textContent = words ? "Draft Updated" : "Ready to Draft";
