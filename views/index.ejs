        const text = String(key || "peer");
        for (let index = 0; index < text.length; index += 1) {
          hash = (hash * 31 + text.charCodeAt(index)) >>> 0;
        }
        const column = hash % 3;
        const row = Math.floor(hash / 3) % 3;
        const left = Math.max(
          14,
          Math.min(window.innerWidth - 196, 18 + column * 196),
        );
        const top = Math.max(
          98,
          Math.min(window.innerHeight - 196, 118 + row * 154),
        );
        return { left, top };
