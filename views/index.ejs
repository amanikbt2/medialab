      function saveHistory() {
        const editor = document.getElementById("text-input");
        if (!editor) return;
        const content = editor.innerHTML;
        if (undoStack.length > 0 && undoStack[undoStack.length - 1] === content)
          return;
        undoStack.push(content);
        if (undoStack.length > MAX_HISTORY) undoStack.shift();
        redoStack = [];
        updateUndoRedoButtons();
      }
      function undo() {
        const editor = document.getElementById("text-input");
        if (!editor || undoStack.length <= 1) return;
        redoStack.push(editor.innerHTML);
        editor.innerHTML = undoStack.pop();
        updateUndoRedoButtons();
        updateWordCount();
      }
      function redo() {
        const editor = document.getElementById("text-input");
        if (!editor || redoStack.length === 0) return;
        undoStack.push(editor.innerHTML);
        editor.innerHTML = redoStack.pop();
        updateUndoRedoButtons();
        updateWordCount();
      }
      function updateUndoRedoButtons() {
        const undoBtn = document.getElementById("btn-undo");
        const redoBtn = document.getElementById("btn-redo");
        if (undoBtn) undoBtn.disabled = undoStack.length <= 1;
        if (redoBtn) redoBtn.disabled = redoStack.length === 0;
      }
