              : "Project submitted for marketplace review.",
            "success",
          );
        } catch (error) {
          stopMarketplaceSubmitProgressPulse();
          failUniversalProgress("Marketplace submit failed.");
          marketplaceSubmitState = createEmptyMarketplaceSubmitState();
          mountMarketplaceTool("all");
          showBuilderSnackbar(
