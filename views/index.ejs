      function openVirtualDbModal({
        title = "VirtualDB",
        subtitle = "",
        primaryLabel = "Continue",
        primaryBusyLabel = "Working...",
        bodyHtml = "",
        onPrimary = null,
      } = {}) {
        const layer = document.getElementById("virtualdb-modal-layer");
