        );
      }
      function snapBuilderWorkspaceValue(value = 0, step = 20) {
        const safeStep = Math.max(4, Number(step) || 20);
        return Math.ceil(Math.max(0, Number(value) || 0) / safeStep) * safeStep;
      }
      function getBuilderDesktopBaseWidth(container) {
        const containerWidth = Math.max(320, container?.clientWidth || 0);
        const sideGutter = Math.min(
          140,
          Math.max(56, Math.round(containerWidth * 0.085)),
        );
        return Math.min(1680, Math.max(960, containerWidth - sideGutter * 2));
      }
      function updateBuilderCanvasWorkspaceSize() {
        const canvas = document.getElementById("web-canvas");
        const container = document.getElementById("canvas-container");
        if (!canvas || !container) return;
        const containerWidth = Math.max(320, container.clientWidth || 0);
        const computed = window.getComputedStyle(canvas);
        const gridStep = Math.max(
          20,
          parseFloat(String(computed.backgroundSize || "20").split(" ")[0]) ||
            20,
        );
        const buffer = gridStep * 5;
        const containerHeight = Math.max(520, container.clientHeight - 24);
        // Keep a consistent premium gutter so canvas doesn't feel edge-to-edge.
        const defaultWidth = getBuilderDesktopBaseWidth(container);
        const baseWidth = Math.max(
          320,
          parseInt(canvas.dataset.baseWidth || String(defaultWidth), 10) ||
            defaultWidth,
        );
        let furthestRight = 0;
        let furthestBottom = 0;
        Array.from(canvas.children).forEach((child) => {
          if (isBuilderCanvasWorkspaceHelperNode(child)) return;
          const childStyle = window.getComputedStyle(child);
          if (childStyle.display === "none" || childStyle.position === "fixed")
            return;
          furthestRight = Math.max(
            furthestRight,
            child.offsetLeft + child.offsetWidth,
          );
          furthestBottom = Math.max(
            furthestBottom,
            child.offsetTop + child.offsetHeight,
          );
        });
        const hasCanvasContent = furthestRight > 0 || furthestBottom > 0;
        if (!hasCanvasContent && builderViewportMode === "desktop") {
          canvas.dataset.baseWidth = String(defaultWidth);
        }
        const stableBaseWidth =
          !hasCanvasContent && builderViewportMode === "desktop"
            ? defaultWidth
            : baseWidth;
        const nextWidth = Math.max(
          stableBaseWidth,
          snapBuilderWorkspaceValue(furthestRight + buffer, gridStep),
        );
        const nextHeight = Math.max(
          containerHeight,
          snapBuilderWorkspaceValue(furthestBottom + buffer, gridStep),
        );
        const currentWidth = parseFloat(canvas.style.width || "0");
        const currentHeight = parseFloat(canvas.style.height || "0");
        if (
          Math.abs(currentWidth - nextWidth) < 1 &&
          Math.abs(currentHeight - nextHeight) < 1
        ) {
          return;
        }
        canvas.style.width = `${nextWidth}px`;
        canvas.style.minWidth = `${stableBaseWidth}px`;
        canvas.style.height = `${nextHeight}px`;
        canvas.style.minHeight = `${nextHeight}px`;
      }
      function requestBuilderCanvasWorkspaceSize() {
        cancelAnimationFrame(builderCanvasSizeRaf);
