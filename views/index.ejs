            };
          }
        }
        const issues = getMarketplaceValidationIssues();
        if (issues.length) {
          const message =
            issues.length > 1
              ? `${issues[0]} ${issues[1]}`
              : issues[0] ||
                "Complete all marketplace steps before submitting.";
          showBuilderSnackbar(message, "error");
          return;
        }
        beginUniversalProgress(
