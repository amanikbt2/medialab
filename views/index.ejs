      function addBuilderNodeToFolder(node, folderPath = "") {
        ensureBuilderProjectFiles();
        const targetFolder = getBuilderFolderNode(folderPath);
        targetFolder.children = Array.isArray(targetFolder.children)
          ? targetFolder.children
          : [];
        const existingNames = new Set(
          targetFolder.children.map((child) =>
            String(child?.name || "").toLowerCase(),
          ),
        );
        let baseName =
          String(node?.name || "").trim() ||
          (node?.type === "folder" ? "folder" : "file.txt");
        let nextName = baseName;
        let suffix = 2;
        while (existingNames.has(nextName.toLowerCase())) {
          const extension =
            node?.type === "file" && baseName.includes(".")
              ? `.${baseName.split(".").pop()}`
              : "";
          const stem = extension
            ? baseName.slice(0, -extension.length)
            : baseName;
          nextName = `${stem}-${suffix}${extension}`;
          suffix += 1;
        }
        node.name = nextName;
        targetFolder.children.push(node);
        renderBuilderProjectExplorer();
        return normalizeBuilderFilePath(
          folderPath ? `${folderPath}/${node.name}` : node.name,
        );
      }
