      function upsertNotificationFromSocket(payload = {}) {
        if (!payload?._id) return;
        const existingIndex = notificationsList.findIndex(
          (item) => String(item?._id || "") === String(payload._id || ""),
        );
        const nextItem = {
          ...normalizeNotificationItem(payload),
          isRead: false,
        };
        if (existingIndex >= 0) {
          notificationsList.splice(existingIndex, 1);
        }
        applyNotificationSnapshot([nextItem, ...notificationsList]);
