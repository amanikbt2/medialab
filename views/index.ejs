        // Strip contenteditable from any remaining elements
        clone.querySelectorAll("[contenteditable]").forEach((node) => {
          node.removeAttribute("contenteditable");
        });
        const interactionEntries = [];
        clone.querySelectorAll("[data-interactions]").forEach((sourceNode) => {
          const clonedNodeId = String(sourceNode.id || "").trim();
          if (!clonedNodeId) return;
          Object.entries(
