      // Keyboard Shortcuts
      function setupKeyboardShortcuts() {
        const editor = document.getElementById("text-input");
        editor.addEventListener("keydown", (e) => {
          if ((e.ctrlKey || e.metaKey) && e.key.toLowerCase() === "s") {
            e.preventDefault();
            saveHistory();
            showWordRibbon();
          }
          if ((e.ctrlKey || e.metaKey) && e.key === "z") {
            e.preventDefault();
            undo();
          }
          if ((e.ctrlKey || e.metaKey) && e.key.toLowerCase() === "b") {
            e.preventDefault();
            format("bold");
          }
          if ((e.ctrlKey || e.metaKey) && e.key.toLowerCase() === "i") {
            e.preventDefault();
            format("italic");
          }
          if ((e.ctrlKey || e.metaKey) && e.key.toLowerCase() === "u") {
            e.preventDefault();
            format("underline");
          }
          if (
            (e.ctrlKey || e.metaKey) &&
            e.shiftKey &&
            e.key.toLowerCase() === "7"
          ) {
            e.preventDefault();
            applyListStyle("number");
          }
          if (
            (e.ctrlKey || e.metaKey) &&
            e.shiftKey &&
            e.key.toLowerCase() === "8"
          ) {
            e.preventDefault();
            applyListStyle("bullet");
          }
          if (
            (e.ctrlKey || e.metaKey) &&
            e.shiftKey &&
            e.key.toLowerCase() === "h"
          ) {
            e.preventDefault();
            setParagraphStyle("H1");
          }
          if (
            (e.ctrlKey || e.metaKey) &&
            e.shiftKey &&
            e.key.toLowerCase() === "j"
          ) {
            e.preventDefault();
            setParagraphStyle("H2");
          }
          if (
            (e.ctrlKey || e.metaKey) &&
            e.shiftKey &&
            e.key.toLowerCase() === "k"
          ) {
            e.preventDefault();
            setParagraphStyle("H3");
          }
          if (
            (e.ctrlKey || e.metaKey) &&
            (e.key === "y" || (e.shiftKey && e.key === "z"))
          ) {
            e.preventDefault();
            redo();
          }
          if (
