              String(marketplaceDraftListing.description || "")
                .trim()
                .slice(0, 180),
            sourceType: "template-code",
            projectId: "template-code",
            projectLabel: "Pasted template code",
            sourceHtml: templateCode,
            sourceEntryPath: "index.html",
            sourceFiles: [
              {
                path: "index.html",
                name: "index.html",
                content: templateCode,
                mimeType: "text/html",
