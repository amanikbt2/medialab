      .canvas-element {
        touch-action: none;
        cursor: default;
        box-sizing: border-box;
        transform-origin: top left;
        will-change: left, top, width, height;
        position: absolute;
        backface-visibility: hidden;
        -webkit-font-smoothing: antialiased;
      }
      .canvas-element.locked .drag-handle,
      .canvas-element.locked .resizer {
        display: none !important;
      }
      .resizer.tl,
      .resizer.br {
        cursor: nwse-resize;
      }
      .resizer.tr,
      .resizer.bl {
        cursor: nesw-resize;
      }
      .resizer.mt,
      .resizer.mb {
        cursor: ns-resize;
      }
      .resizer.ml,
      .resizer.mr {
        cursor: ew-resize;
      }
      .resizer {
        transition: all 0.15s ease;
      }
      .resizer.tl {
        top: -5px;
        left: -5px;
      }
      .resizer.tr {
        top: -5px;
        right: -5px;
      }
      .resizer.bl {
        bottom: -5px;
        left: -5px;
      }
      .resizer.br {
        bottom: -5px;
        right: -5px;
      }
      .resizer.mt {
        top: -5px;
        left: 50%;
        transform: translateX(-50%);
      }
      .resizer.mb {
        bottom: -5px;
        left: 50%;
        transform: translateX(-50%);
      }
      .resizer.ml {
        left: -5px;
        top: 50%;
        transform: translateY(-50%);
      }
      .resizer.mr {
        right: -5px;
        top: 50%;
        transform: translateY(-50%);
