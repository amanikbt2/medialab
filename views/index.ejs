      async function maybeOfferToCollaborationPeer(
        peerSocketId = "",
        force = false,
      ) {
        const pc = createCollaborationPeerConnection(peerSocketId);
        if (!pc) return;
        const entry = collaborationPeerConnections.get(peerSocketId) || {};
        updateCollaborationPeerSenders(pc);
        const self = getCollaborationSelfUser();
        const peer =
          collaborationUsers.find(
            (user) =>
              String(user.socketId || "") === String(peerSocketId || ""),
          ) || null;
        const selfLive = Boolean(
          collaborationAudioEnabled ||
          collaborationVideoEnabled ||
          collaborationUserHasLiveMedia(self),
        );
        const peerLive = Boolean(collaborationUserHasLiveMedia(peer));
        const shouldInitiate =
          selfLive && !peerLive
            ? true
            : !selfLive && peerLive
              ? false
              : String(socket.id || "") > String(peerSocketId || "");
