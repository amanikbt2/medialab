          String(device.platform || "").toLowerCase(),
          String(device.userAgent || "").toLowerCase(),
          device.screenWidth || 0,
          device.screenHeight || 0,
          device.devicePixelRatio || 1,
          device.maxTouchPoints || 0,
          device.coarsePointer ? 1 : 0,
          device.hoverCapable ? 1 : 0,
