      function updateDocumentOutline() {
        const editor = document.getElementById("text-input");
        const outline = document.getElementById("document-outline");
        if (!editor || !outline) return;
        const headings = Array.from(editor.querySelectorAll("h1, h2, h3"));
        if (!headings.length) {
          outline.innerHTML =
            '<button type="button">Start with a heading to build your outline</button>';
          return;
        }
        outline.innerHTML = "";
        headings.forEach((heading, index) => {
          const text = heading.textContent.trim() || `Section ${index + 1}`;
          const id = buildOutlineHeadingId(text, index);
          heading.id = id;
          const button = document.createElement("button");
          button.type = "button";
          button.textContent = `${heading.tagName === "H1" ? "H1" : heading.tagName === "H2" ? "H2" : "H3"} • ${text}`;
          button.onclick = () => scrollToDocumentHeading(id);
          outline.appendChild(button);
