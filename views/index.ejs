      async function handleCollaborationWebrtcSignal(payload = {}) {
        const sourceSocketId = String(payload.sourceSocketId || "").trim();
        const signalType = String(payload.signalType || "").trim();
        if (!sourceSocketId || !signalType) return;
        const self = getCollaborationSelfUser();
        if (
          self &&
          (collaborationAudioEnabled ||
            collaborationVideoEnabled ||
            collaborationUserHasLiveMedia(self))
        ) {
          await ensureCollaborationLocalMedia(
            getRequestedCollaborationMediaModeForState(
              collaborationAudioEnabled || Boolean(self.canAudio),
              collaborationVideoEnabled || Boolean(self.canVideo),
            ),
          );
        }
        const pc = createCollaborationPeerConnection(sourceSocketId);
        if (!pc) return;
        const entry = collaborationPeerConnections.get(sourceSocketId) || {
          pc,
          lastSignature: "",
          makingOffer: false,
          ignoreOffer: false,
          isSettingRemoteAnswerPending: false,
          polite: String(socket.id || "") < String(sourceSocketId || ""),
        };
        if (signalType === "offer" && payload.data) {
          const readyForOffer =
            !entry.makingOffer &&
            (pc.signalingState === "stable" ||
              entry.isSettingRemoteAnswerPending);
          const offerCollision = !readyForOffer;
          entry.ignoreOffer = !entry.polite && offerCollision;
          collaborationPeerConnections.set(sourceSocketId, entry);
          if (entry.ignoreOffer) {
