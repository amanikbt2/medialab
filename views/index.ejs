            const ratio = width / height;
            if (width > maxW) {
              width = maxW;
              height = width / ratio;
            }
            if (height > maxH) {
              height = maxH;
              width = height * ratio;
            }
            const x = (pageWidth - width) / 2;
            const y = (pageHeight - height) / 2;
