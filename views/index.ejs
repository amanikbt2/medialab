            String(marketplaceEditingListingId || "").trim(),
          );
          const res = await fetch(
            isEditingSale
              ? `/api/marketplace/${encodeURIComponent(marketplaceEditingListingId)}`
              : "/api/marketplace",
            {
              method: isEditingSale ? "PATCH" : "POST",
              credentials: "include",
              headers: { "Content-Type": "application/json" },
              body: JSON.stringify(marketplaceDraftListing),
            },
          );
          stopMarketplaceSubmitProgressPulse();
          setMarketplaceSubmitState({
            active: true,
            percent: 74,
            message: isEditingSale
              ? "Finalizing your marketplace update..."
              : "Finalizing your review submission...",
          });
          const data = await res.json();
          if (!res.ok || !data.success) {
            throw new Error(data.message || "Could not submit the listing.");
          }
          completeUniversalProgress(
            isEditingSale
              ? "Marketplace listing updated."
              : "Marketplace listing submitted.",
          );
          setMarketplaceSubmitState({
            active: true,
            percent: 100,
            message: isEditingSale
              ? "Update complete. Opening My Sales..."
              : "Submission complete. Opening My Sales...",
          });
          marketplaceDraftListing = createEmptyMarketplaceDraftListing();
          marketplaceEditingListingId = "";
          marketplaceUploadState = createEmptyMarketplaceUploadState();
          marketplaceCreateStep = 1;
          marketplaceActiveTab = "mine";
          await refreshMarketplaceData();
          stopMarketplaceSubmitProgressPulse();
          marketplaceSubmitState = createEmptyMarketplaceSubmitState();
          mountMarketplaceTool("all");
          showBuilderSnackbar(
            isEditingSale
