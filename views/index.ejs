          progressDiv.classList.remove("hidden");
          statusText.innerText = skippedFilesCount
            ? `Scanning project files... (${skippedFilesCount} skipped)`
            : "Scanning project files...";
          bar.classList.remove("bg-green-500", "bg-rose-500");
          bar.classList.add("bg-cyan-400");
          bar.style.width = "10%";
          percentLabel.innerText = "10%";
        }
