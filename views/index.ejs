        outline.innerHTML = "";
        headings.forEach((heading, index) => {
          const text = heading.textContent.trim() || `Section ${index + 1}`;
          const id = buildOutlineHeadingId(text, index);
          heading.id = id;
          const button = document.createElement("button");
          button.type = "button";
          button.textContent = `${heading.tagName === "H1" ? "H1" : heading.tagName === "H2" ? "H2" : "H3"} • ${text}`;
