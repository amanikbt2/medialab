                  `<ol>${lines
                    .map(
                      (line) =>
                        `<li>${formatAiInlineChatMarkup(
                          line.replace(/^\d+\.\s+/, ""),
                        )}</li>`,
                    )
                    .join("")}</ol>`,
                );
                return;
