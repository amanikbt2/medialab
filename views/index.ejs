        const seenPaths = new Set();
        normalizedTextEntries.forEach((entry) => {
          const imported = importedMap.get(entry.path);
          mergedFiles.push({
            path: entry.path,
            contentBase64: encodeBuilderTextBase64(entry.content),
            mimeType: imported?.mimeType || guessBuilderMimeType(entry.path),
          });
          seenPaths.add(entry.path);
        });
        importedFiles.forEach((file) => {
          const path = normalizeImportedProjectPath(file?.path || "");
