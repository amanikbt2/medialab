      @keyframes rotate { 100% { transform: rotate(360deg); } }
      @keyframes spin { 100% { transform: rotate(360deg); } }
      @keyframes pulse { 0%, 100% { transform: scale(1); opacity: 1; } 50% { transform: scale(1.05); opacity: 0.8; } }
      @keyframes bounce { 0%, 100% { transform: translateY(0); } 50% { transform: translateY(-20px); } }
      @keyframes float { 0%, 100% { transform: translateY(0); } 50% { transform: translateY(-10px); } }
      @keyframes mlFadePulse {
        0%,
        100% {
          opacity: 0.28;
          transform: translateY(0px) scale(0.98);
        }
        50% {
          opacity: 1;
          transform: translateY(-4px) scale(1);
        }
      }
      @keyframes mlBlinkSoft {
        0%,
        48%,
        100% {
          opacity: 1;
        }
        50%,
        52% {
          opacity: 0.18;
        }
      }
      @keyframes mlHueShift {
        0% {
          filter: hue-rotate(0deg) saturate(1);
        }
        50% {
          filter: hue-rotate(90deg) saturate(1.15);
        }
        100% {
          filter: hue-rotate(180deg) saturate(1);
        }
      }
      @keyframes mlFloatBob {
        0%,
        100% {
          transform: translate3d(0, 0, 0);
        }
        50% {
          transform: translate3d(0, -14px, 0);
        }
      }
      @keyframes mlRotateDrift {
        0% {
          transform: rotate(0deg) scale(1);
        }
        50% {
          transform: rotate(8deg) scale(1.03);
        }
        100% {
          transform: rotate(-8deg) scale(1);
        }
      }
      @keyframes mlSlideSweep {
        0% {
          transform: translateX(-28px);
          opacity: 0;
        }
        35% {
          opacity: 1;
        }
        100% {
          transform: translateX(28px);
          opacity: 0.88;
        }
      }
      @keyframes mlWidthBreathe {
        0%,
        100% {
          transform: scaleX(0.86);
        }
        50% {
          transform: scaleX(1.08);
        }
      }
      @keyframes mlOrbitTilt {
        0% {
          transform: rotate(0deg) translateY(0px) scale(1);
        }
        25% {
          transform: rotate(4deg) translateY(-6px) scale(1.02);
        }
        50% {
          transform: rotate(0deg) translateY(-12px) scale(1.04);
        }
        75% {
          transform: rotate(-4deg) translateY(-6px) scale(1.02);
        }
        100% {
          transform: rotate(0deg) translateY(0px) scale(1);
        }
      }
      @keyframes mlBackgroundGlow {
