        const simulateUpload = setInterval(() => {
          // Increment progress
          percent += Math.floor(Math.random() * 5) + 2;
          if (percent >= 100) {
            percent = 100;
            clearInterval(simulateUpload);
            // --- SUCCESS STATE TRANSITION ---
            if (progressBar) {
