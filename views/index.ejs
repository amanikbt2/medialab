          const normalized =
            normalizeImportedProjectPath(rawPath).toLowerCase();
          if (!normalized) return true;
          const segments = normalized.split("/").filter(Boolean);
          return segments.some((segment) =>
            ["node_modules", ".git", ".next", ".cache", "coverage"].includes(
              segment,
            ),
          );
        };
