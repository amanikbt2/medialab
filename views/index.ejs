      function getBuilderCanvasMetrics(canvas) {
        const rect = canvas?.getBoundingClientRect?.() || {
          left: 0,
          top: 0,
          width: 1,
          height: 1,
        };
        const scaleX = canvas?.offsetWidth
          ? canvas.offsetWidth / (rect.width || 1)
          : 1;
        const scaleY = canvas?.offsetHeight
          ? canvas.offsetHeight / (rect.height || 1)
          : 1;
        const scroller = getBuilderCanvasScroller(canvas);
        const scrollLeft = scroller?.scrollLeft || 0;
        const scrollTop = scroller?.scrollTop || 0;
        return {
          rect,
          scaleX: Number.isFinite(scaleX) && scaleX > 0 ? scaleX : 1,
          scaleY: Number.isFinite(scaleY) && scaleY > 0 ? scaleY : 1,
          scroller,
          scrollLeft,
          scrollTop,
        };
      }
      function initCanvasSelection(canvas) {
        canvas.onpointerdown = (e) => {
          if (e.target !== canvas) return;
          if (builderCodeMode) return;
          if (isCollaborationViewOnly()) return;
          const metrics = getBuilderCanvasMetrics(canvas);
          const startX =
            (e.clientX - metrics.rect.left) * metrics.scaleX +
            metrics.scrollLeft;
          const startY =
            (e.clientY - metrics.rect.top) * metrics.scaleY + metrics.scrollTop;
          let moved = false;
          deselectAll();
          if (!selectionBoxEl) return;
          selectionBoxEl.classList.remove("hidden");
          Object.assign(selectionBoxEl.style, {
            left: `${startX}px`,
            top: `${startY}px`,
            width: "0px",
            height: "0px",
          });
          const onMove = (ev) => {
            moved = true;
            const nextMetrics = getBuilderCanvasMetrics(canvas);
            const currentX =
              (ev.clientX - nextMetrics.rect.left) * nextMetrics.scaleX +
              nextMetrics.scrollLeft;
            const currentY =
              (ev.clientY - nextMetrics.rect.top) * nextMetrics.scaleY +
              nextMetrics.scrollTop;
            const left = Math.min(startX, currentX);
            const top = Math.min(startY, currentY);
            const width = Math.abs(currentX - startX);
            const height = Math.abs(currentY - startY);
            Object.assign(selectionBoxEl.style, {
              left: `${left}px`,
              top: `${top}px`,
              width: `${width}px`,
              height: `${height}px`,
            });
          };
          const onUp = () => {
            document.removeEventListener("pointermove", onMove);
            document.removeEventListener("pointerup", onUp);
            selectionBoxEl.classList.add("hidden");
            if (!moved) return;
            const box = {
              left: parseFloat(selectionBoxEl.style.left || "0"),
              top: parseFloat(selectionBoxEl.style.top || "0"),
              right:
                parseFloat(selectionBoxEl.style.left || "0") +
                parseFloat(selectionBoxEl.style.width || "0"),
              bottom:
                parseFloat(selectionBoxEl.style.top || "0") +
                parseFloat(selectionBoxEl.style.height || "0"),
            };
            multiSelectMode = true;
            Array.from(
