          linear-gradient(160deg, rgba(2, 6, 23, 0.98), rgba(8, 15, 30, 0.99));
        backdrop-filter: blur(18px);
      }
      html.collaboration-booting .collaboration-preboot-overlay {
        display: flex;
      }
      .collaboration-preboot-card {
        width: min(94vw, 500px);
        border-radius: 2rem;
        border: 1px solid rgba(34, 211, 238, 0.18);
        background:
          radial-gradient(
            circle at top left,
            rgba(34, 211, 238, 0.16),
            transparent 44%
