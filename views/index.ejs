                blocks.push(
                  `<ul>${lines
                    .map(
                      (line) =>
                        `<li>${formatAiInlineChatMarkup(
                          line.replace(/^[-*]\s+/, ""),
                        )}</li>`,
                    )
                    .join("")}</ul>`,
                );
                return;
