          if (highestIntersectingIdx !== -1) {
            const highestEl = ordered[highestIntersectingIdx];
            const newOrdered = [];
            nonTargets.forEach((nt) => {
              newOrdered.push(nt);
              if (nt === highestEl) newOrdered.push(...targetsInOrder);
