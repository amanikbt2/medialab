      async function startVideoConversion() {
        const format = document.getElementById("audio-format").value;
        const btn = document.getElementById("convert-btn");
        const progressDiv = document.getElementById("universal-progress");
        const bar = document.getElementById("universal-bar");
        const percentLabel = document.getElementById("universal-percent");
        const statusText = document.getElementById("universal-status-text");
        // 1. Validation: Ensure a file was actually uploaded first
        if (!selectedVideoFile) {
          alert("Please upload a video first!");
          return;
        }
        // 2. UI State: Disable button and show progress bar
        btn.disabled = true;
        btn.innerHTML = `<i class="fas fa-spinner animate-spin mr-2"></i> Initializing Engine...`;
        if (progressDiv) {
          progressDiv.classList.remove("hidden");
          statusText.innerText = "Connecting to AI Engine...";
        }
        try {
          // 3. Send the request to the backend
          const response = await fetch("/api/convert/video-to-audio", {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({
              videoFile: selectedVideoFile,
              socketId: socket.id,
              requestedFormat: format,
            }),
          });
          const result = await response.json();
          if (result.success) {
            // 4. Success UI Fix: Ensure bar hits 100% Green
            if (bar) {
              bar.style.width = "100%";
              bar.classList.replace("bg-cyan-500", "bg-green-500");
              bar.classList.add("shadow-[0_0_20px_rgba(34,197,94,0.6)]");
            }
            if (percentLabel) percentLabel.innerText = "100%";
            if (statusText) statusText.innerText = "✨ AI Extraction Complete!";
            // 5. Transform the main button into a Green Download Button
            showDownloadState(result.audioUrl, "video");
            // 6. Save to Local History (for Guests) and Refresh UI
            saveProjectToHistory({
              toolType: "Video → Audio",
              fileName: selectedVideoFile,
              fileUrl: result.audioUrl,
            });
            // 7. Refresh Sidebar automatically
            if (typeof updateSidebarHistory === "function") {
              updateSidebarHistory(currentUser ? currentUser.projects : null);
            }
            console.log("✅ Conversion Success:", result.audioUrl);
            // 8. Auto-hide the progress bar after 4 seconds
            setTimeout(() => {
              progressDiv.classList.add("hidden");
              // Reset bar colors for the next use
              bar.style.width = "0%";
              bar.classList.replace("bg-green-500", "bg-cyan-500");
              bar.classList.remove("shadow-[0_0_20px_rgba(34,197,94,0.6)]");
            }, 4000);
          } else {
            throw new Error(
              result.message || "Engine failed to process video.",
