      function isBuilderCanvasWorkspaceHelperNode(node) {
        if (!(node instanceof HTMLElement)) return true;
        const helperClasses = [
          "builder-selection-chip",
          "builder-guide",
          "builder-layout-guide-overlay",
          "builder-layout-slot-guide",
          "builder-selection-box",
          "builder-layout-scroll-assist",
        ];
        return helperClasses.some((className) =>
