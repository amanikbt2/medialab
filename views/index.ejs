        const exactEntry = files.find(
          (file) =>
            String(file?.path || file?.name || "")
              .trim()
              .replace(/^\/+/, "") === entryPath,
        );
        if (exactEntry?.content) {
          return String(exactEntry.content || "").trim();
        }
        const fallbackHtmlFile = files.find((file) =>
