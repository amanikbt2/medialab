      async function advanceAccountSuspendStep() {
        if (accountSuspendInFlight) return;
        const referralInput = String(
          document.getElementById("suspend-account-referral-input")?.value ||
            "",
        ).trim();
        const expectedReferralCode = String(
          currentReferralStatus?.referralCode ||
            currentUser?.referralCode ||
            "",
        ).trim();
        const captchaInput = String(
          document.getElementById("suspend-account-captcha-input")?.value || "",
        )
          .trim()
          .toUpperCase();
        const reason = String(
          document.getElementById("suspend-account-reason-input")?.value || "",
        ).trim();
        if (accountSuspendStep === "verify") {
          if (!referralInput || referralInput !== expectedReferralCode) {
            setAccountSuspendError(
              "Enter the referral code linked to your account.",
            );
            return;
          }
          if (!captchaInput || captchaInput !== accountSuspendCaptcha) {
            setAccountSuspendError(
              "The security code does not match. Please try again.",
            );
            generateAccountSuspendCaptcha();
            document.getElementById("suspend-account-captcha-input").value = "";
            return;
          }
          setAccountSuspendError("");
          accountSuspendStep = "reason";
          renderAccountSuspendStep();
          return;
        }
        if (accountSuspendStep === "reason") {
          if (reason.length < 6) {
            setAccountSuspendError(
              "Please enter a short reason before continuing.",
            );
            return;
          }
          setAccountSuspendError("");
          accountSuspendStep = "confirm";
          renderAccountSuspendStep();
          return;
        }
        const confirmed = await openAppDialog({
          chip: "Final Warning",
          title: "Suspend your account permanently?",
          message:
            "Are you sure you want to suspend your account? This process is irreversible and will remove your MediaLab data completely.",
          tone: "error",
          confirmLabel: "Yes, Suspend",
          cancelLabel: "Keep Account",
          destructive: true,
        });
        if (!confirmed) return;
        accountSuspendInFlight = true;
        renderAccountSuspendStep();
        closeAccountSuspendModal();
        closeAccountModal();
        beginUniversalProgress("Suspending your account...", 8, 86);
        const progressStages = [
          [18, "Deleting your projects..."],
          [36, "Removing your GitHub repository..."],
          [58, "Deleting your cloud images..."],
          [78, "Wiping account records from MediaLab..."],
        ];
        let stageIndex = 0;
        const stageTimer = setInterval(() => {
          const stage = progressStages[stageIndex++];
          if (!stage) {
            clearInterval(stageTimer);
            return;
          }
          updateUniversalProgress(stage[0], stage[1]);
        }, 900);
        try {
          const res = await fetch("/api/account/suspend", {
            method: "POST",
            credentials: "include",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({
              referralCode: referralInput,
              reason,
            }),
          });
          const data = await res.json().catch(() => ({}));
          clearInterval(stageTimer);
          if (res.status === 401) {
            failUniversalProgress("Account suspension could not continue.");
            await handleAuthSessionFailure(
              data.message || "Your session ended. Please sign in again.",
            );
            accountSuspendInFlight = false;
            resetAccountSuspendFlow();
            return;
          }
          if (!res.ok || !data.success) {
            throw new Error(
              data.message || "Could not suspend this account right now.",
            );
          }
          completeUniversalProgress("Account suspended successfully.");
          clearClientAuthState();
          await openAppDialog({
            chip: "Account Suspended",
            title: "Your account has been removed",
            message:
              "MediaLab completed the suspension process and removed the account data tied to this profile.",
            tone: "success",
            confirmLabel: "OK",
            cancelLabel: "Close",
          });
          window.location.href = "/";
        } catch (error) {
          clearInterval(stageTimer);
          failUniversalProgress("Account suspension failed.");
          accountSuspendInFlight = false;
          document
            .getElementById("account-suspend-modal")
            ?.classList.remove("hidden");
          document
            .getElementById("account-suspend-modal")
            ?.classList.add("flex");
          renderAccountSuspendStep();
          setAccountSuspendError(
            error.message || "Could not suspend this account right now.",
          );
        }
      }
