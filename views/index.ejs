                  .filter(
                    (cls) =>
                      ![
                        "canvas-element",
                        "absolute",
                        "group",
                        "transition-shadow",
                        "active:cursor-grabbing",
                        "ring-4",
                        "ring-cyan-400",
                      ].includes(cls),
                  )
                  .join(" "),
                customCssRules: normalizeCustomCssRules(
                  JSON.parse(existingEl.dataset.customCssRules || "[]"),
