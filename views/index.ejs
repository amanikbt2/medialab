          // Real modal with backdrop
          if (elementType === "modal") {
            return {
              html: `<div class="ml-modal-backdrop" style="position: fixed; top: 0; left: 0; right: 0; bottom: 0; background-color: rgba(0, 0, 0, 0.5); display: flex; align-items: center; justify-content: center; z-index: 1000; border-radius: 0; padding: 0; margin: 0;">
                    <div class="ml-modal-content" style="background-color: white; border-radius: 12px; padding: 24px; max-width: 500px; box-shadow: 0 25px 50px rgba(0,0,0,0.3); animation: ml-modal-enter 0.3s ease-out;">
                      <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 16px;">
