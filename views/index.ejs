              <span class="text-[10px] font-black uppercase tracking-[0.2em] text-slate-500">JavaScript</span>
              <textarea rows="9" oninput="builderInteractionDraft.code = this.value" class="mt-2 w-full rounded-[1.6rem] border border-white/10 bg-slate-950/90 px-4 py-3 text-sm leading-6 text-white outline-none focus:border-cyan-400 font-mono" placeholder="console.log(event, source);">${escapeHtmlText(draft.code || getDefaultBuilderInteractionCode(draft.eventName))}</textarea>
            </label>
            <div class="rounded-[1.4rem] border border-white/10 bg-white/[0.03] px-4 py-3 text-xs leading-6 text-slate-400">
              <span class="font-black uppercase tracking-[0.14em] text-slate-300">Available:</span>
              <span class="ml-2"><span class="font-black text-white">event</span>, <span class="font-black text-white">source</span>, <span class="font-black text-white">window</span>, <span class="font-black text-white">document</span></span>
            </div>
          </div>`;
        }
        container.innerHTML = html;
      }
      function startBuilderInteractionTargetPick() {
        builderInteractionPickMode = true;
        showBuilderSnackbar("Click the target element on the canvas.", "info");
      }
      function createInteractionSectionTarget() {
        if (!builderInteractionDraft) return;
        const nextId = createBuilderSection(
          builderInteractionDraft.sectionName || "Section",
        );
        if (!nextId) {
          showBuilderSnackbar("Could not create a new section.", "error");
          return;
        }
        builderInteractionDraft.targetId = nextId;
        renderBuilderInteractionFields();
        showBuilderSnackbar(
          "Section created and selected as target.",
          "success",
        );
      }
      function confirmBuilderInteractionAction() {
        if (!builderInteractionDraft) return;
        const draft = builderInteractionDraft;
        if (draft.actionType === "toggle" && !draft.targetId) {
          showBuilderSnackbar("Select a target element first.", "error");
          return;
        }
        if (draft.actionType === "addSection" && !draft.targetId) {
          showBuilderSnackbar(
            "Select or create a section target first.",
            "error",
          );
          return;
        }
        if (draft.actionType === "alert" && !String(draft.value || "").trim()) {
          showBuilderSnackbar("Enter an alert message first.", "error");
          return;
        }
        if (
          draft.actionType === "redirect" &&
          !String(draft.url || "").trim()
        ) {
          showBuilderSnackbar("Enter a destination URL first.", "error");
          return;
        }
        if (
          draft.actionType === "playSound" &&
          !String(draft.soundUrl || "").trim()
        ) {
          showBuilderSnackbar("Enter a sound URL first.", "error");
          return;
        }
        if (
          draft.actionType === "customCode" &&
          !String(draft.code || "").trim()
        ) {
          showBuilderSnackbar("Write your custom JavaScript first.", "error");
          return;
        }
        currentInspectorState.attributes.interactions =
          currentInspectorState.attributes.interactions || {};
        currentInspectorState.attributes.interactions[draft.eventName] = {
          actionType: draft.actionType,
          targetId: draft.targetId || "",
          sectionName: draft.sectionName || "",
          value: draft.value || "",
          url: draft.url || "",
          soundUrl: draft.soundUrl || "",
          code: draft.code || "",
        };
        syncInspectorUI(true);
        closeBuilderInteractionModal();
        showBuilderSnackbar("Interaction saved.", "success");
      }
      function removeBuilderInteraction(eventName) {
        if (!currentInspectorState.attributes.interactions) return;
        delete currentInspectorState.attributes.interactions[eventName];
        syncInspectorUI(true);
        showBuilderSnackbar("Interaction removed.", "success");
      }
      function toggleElementPicker(event) {
        const picker = document.getElementById("element-picker");
        const trigger =
          event?.currentTarget ||
          document.getElementById("insert-elements-trigger") ||
          document.getElementById("tab-insert");
        if (!picker || !trigger) return;
        const willOpen = picker.classList.contains("hidden");
        picker.classList.toggle("hidden");
        if (!willOpen) return;
        const rect = trigger.getBoundingClientRect();
        const pickerWidth = Math.min(window.innerWidth - 16, 360);
        const top = rect.bottom + 10;
        let left = rect.left;
        if (window.innerWidth <= 640) {
          left = Math.max(
            8,
            Math.min(
              (window.innerWidth - pickerWidth) / 2,
              window.innerWidth - pickerWidth - 8,
            ),
          );
        } else {
          left = Math.max(
            12,
            Math.min(left, window.innerWidth - pickerWidth - 12),
          );
        }
        picker.style.top = `${top}px`;
        picker.style.left = `${left}px`;
        picker.style.transform = "none";
        handleBuilderTutorialEvent("element-picker-opened", { opened: true });
      }
      function closeSmartInspector() {
        const modal = document.getElementById("smart-inspector");
        modal.classList.add("hidden");
        modal.style.removeProperty("padding-top");
        modal.style.removeProperty("align-items");
        modal.style.removeProperty("justify-content");
        resetSmartInspectorState();
      }
      function deselectAll() {
        document
          .querySelectorAll("#web-canvas .builder-selection-chip")
          .forEach((node) => node.remove());
        document
          .querySelectorAll("#web-canvas .builder-layout-scroll-assist")
          .forEach((node) => node.remove());
        selectedElements.forEach((el) =>
          el.classList.remove(
            "ring-4",
            "ring-cyan-400",
            "selected-premium",
            "selected-secondary",
          ),
        );
        if (selectedEl && !selectedElements.includes(selectedEl)) {
          selectedEl.classList.remove(
            "ring-4",
            "ring-cyan-400",
            "selected-premium",
            "selected-secondary",
          );
        }
        selectedEl = null;
        selectedElements = [];
      }
      function selectElement(el) {
        selectedElements = [el];
        syncSelectedElementState();
      }
      function handleRightClick(e) {
        const el = e.target.closest(".canvas-element");
        if (el) {
          e.preventDefault();
          openSmartInspector(el.getAttribute("data-type"), el);
        }
      }
      function rgbToHex(rgb) {
        if (!rgb || rgb.startsWith("#")) return rgb || "#22d3ee";
        const nums = rgb.match(/\d+/g);
        return nums
          ? "#" +
              nums
                .map((n) => parseInt(n).toString(16).padStart(2, "0"))
                .join("")
          : "#22d3ee";
      }
      function splitGradientArguments(value = "") {
        const args = [];
        let current = "";
        let depth = 0;
        for (const char of String(value)) {
          if (char === "(") depth += 1;
          if (char === ")") depth = Math.max(0, depth - 1);
          if (char === "," && depth === 0) {
            args.push(current.trim());
            current = "";
            continue;
          }
          current += char;
        }
        if (current.trim()) args.push(current.trim());
        return args;
      }
      function parseGradientStyle(backgroundImage = "") {
        const match = String(backgroundImage || "").match(
          /linear-gradient\((.*)\)/i,
        );
        if (!match) {
          return {
            angle: "135deg",
            primary: "#22d3ee",
            secondary: "#0f172a",
          };
        }
        const parts = splitGradientArguments(match[1]);
        const hasAngle = /deg|turn|rad/.test(parts[0] || "");
        const colorParts = hasAngle ? parts.slice(1) : parts;
        return {
          angle: hasAngle ? parts[0] : "135deg",
          primary: rgbToHex(colorParts[0] || "#22d3ee"),
          secondary: rgbToHex(colorParts[1] || colorParts[0] || "#0f172a"),
        };
      }
      function extractStyles(el) {
        const inner = getElementInnerNode(el);
        const computed = inner ? window.getComputedStyle(inner) : null;
        const wrapperComputed = el ? window.getComputedStyle(el) : null;
        const computedBackgroundImage = computed?.backgroundImage || "";
        const computedBackgroundSize = computed?.backgroundSize || "cover";
        const parsedGradient = parseGradientStyle(computedBackgroundImage);
        return {
          width: el.style.width || wrapperComputed?.width || "260px",
          height: el.style.height || wrapperComputed?.height || "100px",
          top: el.style.top || wrapperComputed?.top || "150px",
          left: el.style.left || wrapperComputed?.left || "150px",
          zIndex: el.style.zIndex || wrapperComputed?.zIndex || "10",
          backgroundMode: computedBackgroundImage.includes("linear-gradient")
            ? "gradient"
            : computedBackgroundImage.includes("url(")
              ? "image"
              : "solid",
          backgroundColor: rgbToHex(
            computedBackgroundImage.includes("linear-gradient")
              ? parsedGradient.primary
              : computed?.backgroundColor || el.style.backgroundColor,
          ),
          backgroundColorSecondary: computedBackgroundImage.includes(
            "linear-gradient",
          )
            ? parsedGradient.secondary
            : "#0f172a",
          backgroundImageUrl: parseBackgroundImageUrl(computedBackgroundImage),
          backgroundSize: computedBackgroundSize,
          gradientAngle: computedBackgroundImage.includes("linear-gradient")
            ? parsedGradient.angle
            : "135deg",
          opacity: el.style.opacity || wrapperComputed?.opacity || "1",
          borderRadius:
            computed?.borderRadius || el.style.borderRadius || "18px",
          color: rgbToHex(computed?.color || el.style.color),
          fontSize: computed?.fontSize || "18px",
          fontWeight: computed?.fontWeight || "600",
          fontFamily: computed?.fontFamily || "Inter, system-ui, sans-serif",
          textAlign: computed?.textAlign || "left",
          lineHeight: computed?.lineHeight || "1.4",
          letterSpacing: computed?.letterSpacing || "0px",
          borderWidth: computed?.borderWidth || "1px",
          borderStyle: computed?.borderStyle || "solid",
          borderColor: rgbToHex(computed?.borderColor || "#cbd5e1"),
          outlineWidth: computed?.outlineWidth || "0px",
          outlineColor: rgbToHex(computed?.outlineColor || "#38bdf8"),
          outlineOffset: computed?.outlineOffset || "0px",
          boxShadow:
            computed?.boxShadow || "0 24px 60px rgba(15, 23, 42, 0.16)",
          backdropFilterBlur: "0px",
          rotate: "0deg",
          mixBlendMode:
            el.style.mixBlendMode || wrapperComputed?.mixBlendMode || "normal",
          padding: computed?.padding || "16px",
          display: computed?.display || "block",
          flexDirection: computed?.flexDirection || "row",
          flexWrap: computed?.flexWrap || "nowrap",
          justifyContent: computed?.justifyContent || "flex-start",
          alignItems: computed?.alignItems || "stretch",
          gap: computed?.gap || "12px",
          overflowX: computed?.overflowX || "auto",
          overflowY: computed?.overflowY || "auto",
          gridTemplateColumns:
            computed?.gridTemplateColumns || "repeat(2, minmax(0, 1fr))",
          gridTemplateRows: computed?.gridTemplateRows || "auto",
          gridColumnMode: inferGridTrackMode(
            computed?.gridTemplateColumns || "repeat(2, minmax(0, 1fr))",
          ),
          gridColumnCount: inferGridTrackCount(
            computed?.gridTemplateColumns || "repeat(2, minmax(0, 1fr))",
            2,
          ),
          gridColumnSize: inferGridTrackSize(
            computed?.gridTemplateColumns || "repeat(2, minmax(0, 1fr))",
            "minmax(0, 1fr)",
          ),
          gridRowMode: inferGridTrackMode(computed?.gridTemplateRows || "auto"),
          gridRowCount: inferGridTrackCount(
            computed?.gridTemplateRows || "auto",
            2,
          ),
          gridRowSize: inferGridTrackSize(
            computed?.gridTemplateRows || "auto",
            "auto",
          ),
          flexItemMode: el.dataset.flexItemMode || "auto",
          flexItemSize: el.dataset.flexItemSize || "220px",
          animationName: computed?.animationName || "none",
          animationDuration: computed?.animationDuration || "1.6s",
          animationTimingFunction:
            computed?.animationTimingFunction || "ease-in-out",
          animationDelay: computed?.animationDelay || "0s",
          animationIterationCount:
            computed?.animationIterationCount || "infinite",
          animationDirection: computed?.animationDirection || "normal",
          animationFillMode: computed?.animationFillMode || "both",
          animationPlayState: computed?.animationPlayState || "running",
          animationStack: normalizeAnimationStack(
            JSON.parse(el.dataset.animationStack || "[]"),
          ),
        };
      }
    </script>
  </body>
</html>
