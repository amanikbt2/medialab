      async function connectVirtualMediaLabDb() {
        dataExplorerLoading = true;
        renderDataExplorerTool();
        try {
          const res = await fetch("/api/virtualdb/connect", {
            method: "POST",
            credentials: "include",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({}),
          });
          const data = await res.json().catch(() => ({}));
          if (!res.ok || !data.success) {
            throw new Error(data.message || "Could not connect VirtualDB.");
          }
          dataExplorerConnected = true;
          dataExplorerEngine = "virtual-medialabdb";
          dataExplorerEngineConfirmed = true;
          dataExplorerDbName = String(data.dbName || "");
          dataExplorerUriLabel = String(data.uriLabel || "");
          await refreshVirtualDbModelIndex();
          dataExplorerChannelId = String(
            data.channelId || dataExplorerChannelId || "",
          );
          dataExplorerSelectedCollection = dataExplorerCollections[0] || "";
          if (dataExplorerSelectedCollection) {
            await loadDataExplorerCollection(dataExplorerSelectedCollection);
          }
          showBuilderSnackbar("VirtualDB connected.", "success");
        } catch (error) {
          showBuilderSnackbar(
            error.message || "Could not connect VirtualDB.",
            "error",
          );
        } finally {
          dataExplorerLoading = false;
          renderDataExplorerTool();
        }
      }

      async function refreshVirtualDbModelIndex() {
        const res = await fetch("/api/virtualdb/models", {
          credentials: "include",
        });
        const data = await res.json().catch(() => ({}));
        if (!res.ok || !data.success) {
          throw new Error(data.message || "Could not load VirtualDB models.");
        }
        const documents = Array.isArray(data.documents) ? data.documents : [];
        virtualDbModelIndex = documents;
        const names = Array.from(
          new Set(
            documents
              .map((doc) => String(doc?.name || "").trim())
              .filter(Boolean),
          ),
        ).sort((a, b) => a.localeCompare(b));
        dataExplorerCollections = names;
        if (
          dataExplorerSelectedCollection &&
          !names.includes(dataExplorerSelectedCollection)
        ) {
          dataExplorerSelectedCollection = "";
        }
        if (!dataExplorerSelectedCollection && names.length) {
          dataExplorerSelectedCollection = names[0];
        }
      }

