      html.collaboration-booting,
      html.collaboration-booting body {
        overflow: hidden;
      }
      /* Full-screen progress overlay: lock page scroll whenever it is visible */
      html:has(#universal-progress:not(.hidden)),
      html:has(#universal-progress:not(.hidden)) body {
        overflow: hidden;
      }
      #universal-progress {
        pointer-events: auto;
      }
      #universal-progress.hidden {
        pointer-events: none;
      }
      .collaboration-preboot-overlay {
        position: fixed;
        inset: 0;
        z-index: 2000000;
        display: none;
        align-items: center;
        justify-content: center;
        padding: 1rem;
        background:
          radial-gradient(
            circle at top left,
            rgba(34, 211, 238, 0.2),
            transparent 38%
          ),
          radial-gradient(
            circle at top right,
            rgba(16, 185, 129, 0.14),
            transparent 30%
