          linear-gradient(180deg, rgba(8, 15, 30, 0.98), rgba(2, 6, 23, 0.98));
        box-shadow: 0 34px 110px rgba(2, 6, 23, 0.6);
        padding: 1.5rem;
      }
      .collaboration-preboot-progress {
        position: relative;
        overflow: hidden;
        height: 0.72rem;
        border-radius: 999px;
        background: rgba(255, 255, 255, 0.08);
      }
      .collaboration-preboot-progress > span {
        position: absolute;
        inset: 0 auto 0 0;
        width: var(--preboot-progress, 14%);
        border-radius: inherit;
        background: linear-gradient(90deg, #22d3ee, #67e8f9);
        box-shadow: 0 0 24px rgba(34, 211, 238, 0.28);
        transition: width 0.28s ease;
      }
      /* --- UI Animations --- */
      .tool-card {
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
      }
      .tool-card:hover {
        transform: translateY(-8px);
        box-shadow: 0 25px 50px -12px rgb(0 212 255 / 0.15);
      }
      .toolbar-item {
        transition: all 0.2s ease;
