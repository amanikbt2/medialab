      function trimNotificationFeed(items = []) {
        const normalizedItems = (Array.isArray(items) ? items : []).map(
          (item) => normalizeNotificationItem(item),
        );
        const unreadItems = normalizedItems
          .filter((item) => !item.isRead)
          .sort(
            (left, right) =>
              new Date(right.createdAt || 0) - new Date(left.createdAt || 0),
          );
        const readItems = normalizedItems
          .filter((item) => item.isRead)
          .sort(
            (left, right) =>
              new Date(right.createdAt || 0) - new Date(left.createdAt || 0),
          )
          .slice(0, 10);
        return [...unreadItems, ...readItems];
      }
      function applyNotificationSnapshot(items = [], unreadCount = null) {
        notificationsList = trimNotificationFeed(
          Array.isArray(items) ? items : [],
        );
        const derivedUnreadCount = notificationsList.filter(
          (item) => !item.isRead,
        ).length;
        void unreadCount;
        // Badge must always reflect unread flags from the fetched list.
        unreadNotificationCount = derivedUnreadCount;
