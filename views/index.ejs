            ],
          };
        }
        if (
          String(marketplaceDraftListing.sourceType || "").trim() === "draft"
        ) {
          const selectedDraft = getMarketplaceDraftProjects().find(
            (item) =>
              String(item?.name || "").trim() ===
              String(marketplaceDraftListing.projectId || "").trim(),
          );
          const draftHtml = resolveMarketplaceDraftHtml(selectedDraft);
          if (draftHtml) {
            marketplaceDraftListing = {
              ...marketplaceDraftListing,
              sourceHtml: draftHtml,
              sourceEntryPath: "index.html",
              sourceFiles:
                marketplaceDraftListing.sourceFiles?.length > 0
                  ? marketplaceDraftListing.sourceFiles
                  : [
                      {
                        path: "index.html",
                        name: "index.html",
                        content: draftHtml,
                        mimeType: "text/html",
                      },
                    ],
            };
          }
        } else if (
          String(marketplaceDraftListing.sourceType || "").trim() === "upload"
