      function extractAgentActionBlocks(responseText = "") {
        const actions = [];
        const regex = /\[ACTION\]\s*([\s\S]*?)\s*\[\/ACTION\]/gi;
        let match;
        while ((match = regex.exec(String(responseText || ""))) !== null) {
          const raw = String(match[1] || "").trim();
          if (!raw) continue;
          const typedMatch = raw.match(
            /^\{([A-Za-z_][\w-]*)\}\s*(\{[\s\S]*\})$/,
          );
          if (typedMatch) {
            const typedType = String(typedMatch[1] || "")
              .trim()
              .toUpperCase();
            const typedPayload = String(typedMatch[2] || "").trim();
            try {
              const parsedPayload = JSON.parse(typedPayload);
              actions.push({ type: typedType, ...(parsedPayload || {}) });
              continue;
            } catch {}
          }
          try {
            const parsed = JSON.parse(raw);
            if (Array.isArray(parsed))
              parsed.forEach((item) => actions.push(item));
            else if (parsed && Array.isArray(parsed.actions))
              parsed.actions.forEach((item) => actions.push(item));
            else actions.push(parsed);
          } catch {
            try {
              const repaired = raw
