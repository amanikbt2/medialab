              styles: {
                width: componentSpec.width,
                height: componentSpec.height,
              },
            };
          }
        }

        // Toggle/Switch - "insert toggle", "add switch", "toggle button", etc.
        if (/\b(?:toggle|switch|on\/off|on-off)\b/.test(text)) {
          const color = extractColorFromPrompt(text, "#10b981");
          const componentSpec = generateRealElementHTML("toggle", { color });
          if (componentSpec) {
            return {
              type: "toggle",
              label: "toggle",
              html: componentSpec.html,
              css: componentSpec.css,
              script:
                "const toggleCheckbox = wrapper.querySelector('input[type=checkbox]'); if(toggleCheckbox) { toggleCheckbox.addEventListener('change', (e) => { console.log('Toggle state:', e.target.checked); }); }",
              styles: {
                width: componentSpec.width,
                height: componentSpec.height,
