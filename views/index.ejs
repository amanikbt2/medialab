      // ====================== 5. INTERACTION ENGINE ======================
      function handleObjectInteraction(e, el) {
        if (e.button !== undefined && e.button !== 0) return;
        if (isCollaborationViewOnly()) return;
        if (el.classList.contains("locked")) return;
        if (e.target.isContentEditable) return;
        if (builderInteractionPickMode && builderInteractionDraft) {
          e.stopPropagation();
          e.preventDefault();
          currentInspectorState.attributes.interactions =
            currentInspectorState.attributes.interactions || {};
          const interaction =
            currentInspectorState.attributes.interactions[
              builderInteractionDraft.eventName
            ] || {};
          interaction.targetId = el.id;
          currentInspectorState.attributes.interactions[
            builderInteractionDraft.eventName
          ] = interaction;
          builderInteractionDraft.targetId = el.id;
          builderInteractionPickMode = false;
          renderBuilderInteractionFields();
          showBuilderSnackbar(`Target selected: ${el.id}`, "success");
          return;
        }
        e.stopPropagation();
        e.preventDefault();
        const isResizer = e.target.classList.contains("resizer");
        const isDragHandle = e.target.closest(".drag-handle");
        const isToolbarControl = e.target.closest(".absolute.-top-10");
        const canDragFromBody = !isResizer && !isToolbarControl;
        const isAlreadySingleSelected =
          !multiSelectMode &&
          selectedElements.length === 1 &&
          selectedElements[0] === el;
        if (
          multiSelectMode &&
          !isResizer &&
          !isDragHandle &&
          !canDragFromBody
        ) {
          if (!selectedElements.includes(el)) {
            addElementSelection(el);
            return;
          }
        }
        if (
          !multiSelectMode ||
          selectedElements.length <= 1 ||
          !selectedElements.includes(el)
        ) {
          selectElement(el);
        }
        if (!isResizer && !isDragHandle && !canDragFromBody) return;
        const movingSelection =
          !isResizer &&
          selectedElements.length > 1 &&
          selectedElements.includes(el);
        const canvas = document.getElementById("web-canvas");
        ensureBuilderGuides(canvas);
        if (
          !isResizer &&
          !movingSelection &&
          el.classList.contains("in-layout-flow")
        ) {
          detachElementFromLayoutFlow(el, canvas);
        }
        const startX = e.clientX,
          startY = e.clientY;
        const canvasRect = canvas.getBoundingClientRect();
        const startRect = el.getBoundingClientRect();
        const startW = Math.max(30, Math.round(startRect.width)),
          startH = Math.max(30, Math.round(startRect.height));
        const startL = el.offsetLeft,
          startT = el.offsetTop;

        // Professional accurate grab offset: where user clicked on the element (viewport coords)
        const grabPointX = startX - startRect.left;
        const grabPointY = startY - startRect.top;

        // Stabilize drag/resize math by freezing auto/% dimensions to px before move.
        if (!movingSelection && !isResizer) {
          const widthText = String(el.style.width || "")
            .trim()
            .toLowerCase();
          const heightText = String(el.style.height || "")
            .trim()
            .toLowerCase();
          if (!widthText || widthText.includes("%") || widthText === "auto") {
            el.style.width = `${startW}px`;
          }
          if (
            !heightText ||
            heightText.includes("%") ||
            heightText === "auto"
          ) {
            el.style.height = `${startH}px`;
          }
        }
        const selectionStarts = movingSelection
          ? selectedElements.map((item) => {
              const itemRect = item.getBoundingClientRect();
              return {
                el: item,
                left: item.offsetLeft,
                top: item.offsetTop,
                grabX: startX - itemRect.left,
                grabY: startY - itemRect.top,
              };
            })
          : [];
        const rType = e.target.classList[1];
        const snap = (value) =>
          builderSnapEnabled
            ? Math.round(value / BUILDER_GRID_SIZE) * BUILDER_GRID_SIZE
            : value;
        const clamp = (value, min, max) =>
          Math.min(Math.max(value, min), Math.max(min, max));
        let activeLayoutPreview = null;
        const onPointerMove = (ev) => {
          if (isResizer) {
            // Resize logic unchanged
            clearLayoutDropGuides();
            const dx = ev.clientX - startX,
