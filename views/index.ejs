        if (!allElements.length) return;
        normalizeCanvasLayerOrder();

        let ordered = allElements
          .map((el, index) => ({
            el,
            zIndex: getElementLayerValue(el),
            index,
          }))
          .sort((a, b) => a.zIndex - b.zIndex || a.index - b.index)
          .map((entry) => entry.el);

        const step = direction === "backward" ? -1 : 1;
        const targetsInOrder = ordered.filter((el) => targetSet.has(el));
        const nonTargets = ordered.filter((el) => !targetSet.has(el));

        if (step > 0) {
          let highestIntersectingIdx = -1;
          targetsInOrder.forEach((target) => {
            const targetIdx = ordered.indexOf(target);
            for (let j = ordered.length - 1; j > targetIdx; j--) {
              if (targetSet.has(ordered[j])) continue;
              if (elementsIntersect(target, ordered[j])) {
                if (j > highestIntersectingIdx) highestIntersectingIdx = j;
                break;
              }
            }
