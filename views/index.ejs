          ).trim();
          if (existing) return existing;
          const created = `ml-${Date.now().toString(36)}-${Math.random().toString(36).slice(2, 10)}`;
          localStorage.setItem("medialab_install_id", created);
          return created;
        } catch {
          return "ml-install-unavailable";
        }
