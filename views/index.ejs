      async function markAllNotificationsRead(options = {}) {
        const { silent = false, force = false } = options;
        if (!loggedIn || !currentUser) return;
        if (!force && !notificationsList.some((item) => !item.isRead)) return;
        try {
          const attemptMarkRead = async () => {
            const res = await fetch("/api/notifications/read", {
              method: "POST",
              credentials: "include",
              headers: { "Content-Type": "application/json" },
              body: JSON.stringify({}),
            });
            const data = await res.json().catch(() => ({}));
            return { res, data };
          };
          let { res, data } = await attemptMarkRead();
          if (res.status === 429) {
            await new Promise((resolve) => setTimeout(resolve, 900));
            ({ res, data } = await attemptMarkRead());
          }
          if (res.status === 401) {
            await handleAuthSessionFailure(
              data.message || "Your session ended. Please sign in again.",
            );
            return;
          }
          if (!res.ok || !data.success)
            throw new Error(
              data.message || "Could not mark notifications as read.",
