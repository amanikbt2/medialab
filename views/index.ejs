          console.error("Fetch Error:", err);
          btn.disabled = false;
          btn.innerHTML = `<i class="fas fa-bolt mr-2"></i> Try Again`;
          if (statusText) statusText.innerText = "Error: Conversion Failed";
          alert(
            "Conversion failed. Please check if the video format is supported.",
          );
        }
      }
