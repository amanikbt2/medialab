      // ====================== 5. INTERACTION ENGINE ======================
      function handleObjectInteraction(e, el) {
        if (e.button !== undefined && e.button !== 0) return;
        if (isCollaborationViewOnly()) return;
        if (el.classList.contains("locked")) return;
        if (e.target.isContentEditable) return;
        const readPx = (node, prop, fallback = 0) => {
          if (!node) return fallback;
          const inline = parseFloat(node.style?.[prop] || "");
          if (Number.isFinite(inline)) return inline;
          try {
            const computed = parseFloat(window.getComputedStyle(node)[prop]);
            if (Number.isFinite(computed)) return computed;
          } catch {}
          const offsetFallback =
            prop === "left"
              ? node.offsetLeft
              : prop === "top"
                ? node.offsetTop
                : prop === "width"
                  ? node.offsetWidth
                  : prop === "height"
                    ? node.offsetHeight
                    : fallback;
          return Number.isFinite(offsetFallback) ? offsetFallback : fallback;
        };
        const normalizeWrapperVisualOffset = (wrapper) => {
          if (!(wrapper instanceof HTMLElement)) return;
          const body = wrapper.querySelector(":scope > .element-body");
          if (!body) return;
          const child = body.firstElementChild;
          if (!(child instanceof HTMLElement)) return;
          const childStyle = String(child.getAttribute("style") || "");
          const childComputed = window.getComputedStyle(child);
