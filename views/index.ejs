          targetFolder.children.map((child) =>
            String(child?.name || "").toLowerCase(),
          ),
        );
        let baseName =
          String(node?.name || "").trim() ||
          (node?.type === "folder" ? "folder" : "file.txt");
        let nextName = baseName;
        let suffix = 2;
        while (existingNames.has(nextName.toLowerCase())) {
          const extension =
            node?.type === "file" && baseName.includes(".")
              ? `.${baseName.split(".").pop()}`
              : "";
