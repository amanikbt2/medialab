      async function submitUpgradeRequest(prefill = null) {
        const name = String(
          prefill?.name ?? document.getElementById("upgrade-name")?.value ?? "",
        ).trim();
        const email = String(
          prefill?.email ??
            document.getElementById("upgrade-email")?.value ??
            "",
        ).trim();
        const message = String(
          prefill?.message ??
            document.getElementById("upgrade-message")?.value ??
            "",
        ).trim();
        const submitBtn = document.getElementById("upgrade-submit-btn");
        const requestedFeature = getUpgradeFeatureLabel();
        if (!name) return alert("Please enter your name.");
        if (!email || !email.includes("@"))
          return alert("Please enter a valid email.");
        if (submitBtn && !prefill) {
          submitBtn.disabled = true;
          submitBtn.textContent = "Sending...";
        }
        try {
          const res = await fetch("/api/upgrade-request", {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            credentials: "include",
            body: JSON.stringify({
              name,
              email,
              message,
              requestedFeature,
              source: currentStudioToolId || "studio-upgrade",
            }),
          });
          const data = await res.json();
          if (!data.success) {
            throw new Error(
              data.message || "Could not save your upgrade request right now.",
            );
          }
          currentPremiumRequest = data.request || currentPremiumRequest;
          closeUpgradeModal();
          if (
            currentUser &&
            currentPremiumRequest &&
            !currentUser.isPro &&
            currentStudioToolId
          ) {
            switchTool(currentStudioToolId);
          }
          alert(
            data.message ||
              "Pending. Your premium request is being processed. You'll get feedback within 48 hours.",
          );
        } catch (error) {
          alert(
            error.message || "Could not save your upgrade request right now.",
          );
        } finally {
          if (submitBtn && !prefill) {
            submitBtn.disabled = false;
            submitBtn.textContent = "Send Request";
          }
        }
      }
