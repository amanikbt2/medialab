        }
        const sourceItem =
          (currentMarketplaceItem?._id === id
            ? currentMarketplaceItem
            : null) ||
          marketplaceItems.find((item) => item._id === id) ||
          marketplaceMySales.find((item) => item._id === id) ||
          marketplacePurchasedItems.find((item) => item._id === id) ||
          null;
        const access = canInteractWithMarketplaceItem(sourceItem);
        const isTemplatePurchase =
          String(sourceItem?.listingKind || "sale").toLowerCase() ===
          "template";
        if (!access.approved) {
          showBuilderSnackbar(
            "This listing is pending approval. Purchase unlocks after approval.",
            "error",
          );
          return;
        }
        if (access.isOwner) {
          showBuilderSnackbar(
            "Unauthorized purchase. You cannot purchase your own project.",
            "error",
          );
          return;
        }
        if (
          !access.canPurchase &&
          String(sourceItem?.viewerPurchaseStatus || "").trim()
        ) {
          const normalizedPurchaseStatus = String(
            sourceItem?.viewerPurchaseStatus || "",
          ).toLowerCase();
          showBuilderSnackbar(
            normalizedPurchaseStatus === "approved"
              ? isTemplatePurchase
                ? "Already added to workspace."
                : "This project is already in your purchased items."
              : "Your purchase request is already pending approval.",
            "error",
          );
          return;
        }
        if (!isTemplatePurchase) {
          const confirmed = await openAppDialog({
            chip: "Marketplace Purchase",
            title: "Start purchase request?",
            message:
              "MediaLab will create a pending purchase for admin review before the project is transferred to your builder dashboard.",
            confirmLabel: "Continue",
            cancelLabel: "Cancel",
          });
          if (!confirmed) return;
        }
        beginUniversalProgress(
          isTemplatePurchase
            ? "Adding template to workspace..."
            : "Submitting purchase request...",
          20,
          92,
        );
        try {
          const res = await fetch(
            `/api/marketplace/${encodeURIComponent(id)}/purchase`,
            {
              method: "POST",
              credentials: "include",
              headers: { "Content-Type": "application/json" },
              body: JSON.stringify({}),
            },
          );
          const data = await res.json();
          if (!res.ok || !data.success) {
            throw new Error(data.message || "Could not submit this purchase.");
          }
          const nextItem = data?.item || null;
          if (nextItem && nextItem._id) {
            if (
              currentMarketplaceItem &&
              String(currentMarketplaceItem._id || "") ===
                String(nextItem._id || "")
            ) {
              currentMarketplaceItem = nextItem;
              renderMarketplaceDetail(currentMarketplaceItem);
            }
            marketplaceItems = (
              Array.isArray(marketplaceItems) ? marketplaceItems : []
            ).map((item) =>
              String(item?._id || "") === String(nextItem._id || "")
                ? nextItem
                : item,
            );
            marketplaceMySales = (
              Array.isArray(marketplaceMySales) ? marketplaceMySales : []
            ).map((item) =>
              String(item?._id || "") === String(nextItem._id || "")
                ? nextItem
                : item,
            );
            marketplacePurchasedItems = (Array.isArray(
              marketplacePurchasedItems,
            )
              ? marketplacePurchasedItems
              : []
            ).some(
              (item) => String(item?._id || "") === String(nextItem._id || ""),
            )
              ? marketplacePurchasedItems.map((item) =>
                  String(item?._id || "") === String(nextItem._id || "")
                    ? nextItem
                    : item,
                )
              : [
                  nextItem,
                  ...(Array.isArray(marketplacePurchasedItems)
                    ? marketplacePurchasedItems
                    : []),
                ];
          }
          completeUniversalProgress("Purchase request sent.");
          await refreshMarketplaceData();
          if (currentStudioToolId === "marketplace")
            mountMarketplaceTool("all");
          showBuilderSnackbar(
            data.message || "Your purchase will be processed within 24 hours.",
            "success",
          );
          if (data.transfer && loggedIn && currentUser) {
            const draftsRes = await fetch("/api/builder-drafts", {
              credentials: "include",
            });
            const draftsData = await draftsRes.json();
            if (draftsData?.success && currentUser) {
              currentUser.builderDrafts = draftsData.drafts || [];
              renderBuilderDrafts();
            }
          }
          if (data.template && loggedIn && currentUser) {
            fetchBuilderCommunityTemplates().catch(() => {});
          }
        } catch (error) {
          failUniversalProgress("Purchase failed.");
          showBuilderSnackbar(
            error.message || "Could not process this purchase.",
            "error",
          );
        }
      }
