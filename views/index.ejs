        box-shadow:
          0 0 0 1px rgba(148, 163, 184, 0.65),
          0 0 0 6px rgba(148, 163, 184, 0.08);
      }
      .canvas-element.selected-premium .resizer,
      .canvas-element.selected-secondary .resizer,
      .canvas-element.selected-premium > .absolute,
