      /**
       * Smart insert command processor - detects, normalizes, and executes insert commands
       * Handles misspellings, casual English, various phrasings
       */
      async function processSmartInsertCommand(userInput = "") {
        const text = String(userInput || "").trim();

        // First check: is this an insert-related command?
        const isInsertIntent = detectInsertIntent(text);
        if (!isInsertIntent) {
          return null; // Not an insert command, return to normal chat
        }

        // Normalize the command to clean format
        const normalized = normalizeInsertCommand(text);

        // Try to execute normalized command through deterministic handler
        setAiAgentStage("parsing");
        const result = runDeterministicBuilderCommand(normalized);

        if (result?.applied) {
          return {
            success: true,
            normalized,
            message: result.message || "Element inserted successfully",
            applied: result.applied,
            actions: result.actions,
          };
        }

        // If deterministic failed, return normalized command for AI processing
        return {
          success: false,
          normalized,
          message: "Normalized command - will use AI agent",
          requiresAI: true,
        };
      }

      function parseAiError(error) {
        // Handle Groq API errors with error details
        if (
          error?.code === "rate_limit_exceeded" ||
          error?.error?.code === "rate_limit_exceeded"
        ) {
          if (error?.type === "tokens" || error?.error?.type === "tokens") {
            return "🚀 Xtra AI is being used by many people now, try again in a minute.";
          }
          return "🚀 Xtra AI is being used by many people now, try again in a minute.";
        }

        // Check for rate limit in error message string
        if (
          typeof error === "string" &&
          error.includes("rate_limit_exceeded")
        ) {
          return "🚀 Xtra AI is being used by many people now, try again in a minute.";
        }

        // Check for token limit messages
        if (
          typeof error === "string" &&
          (error.includes("tokens per minute") ||
            error.includes("Request too large") ||
            error.includes("TPM"))
        ) {
          return "🚀 Xtra AI is being used by many people now, try again in a minute.";
        }

        // Parse JSON error objects (like the Groq error format)
        if (typeof error === "string") {
          try {
            const parsed = JSON.parse(error);
            if (
              parsed?.error?.code === "rate_limit_exceeded" ||
              parsed?.code === "rate_limit_exceeded"
            ) {
              return "🚀 Xtra AI is being used by many people now, try again in a minute.";
            }
            if (parsed?.error?.message) {
              return parsed.error.message;
            }
          } catch (e) {
            // Not JSON, continue with string checks
          }

          // Check raw string for rate limit
          if (
            error.includes("rate_limit") ||
            error.includes("TPM") ||
            error.includes("tokens per minute")
          ) {
            return "🚀 Xtra AI is being used by many people now, try again in a minute.";
          }

          return error;
        }

        // Fallback to original error message if available
        if (error?.message) {
          return error.message;
        }

        return "Could not complete AI request.";
      }

      function createAiRetryMessage(originalPrompt) {
        return `<div style="margin-top: 0.5rem; padding: 0.75rem; border-radius: 0.5rem; background: rgba(34, 211, 238, 0.08); border: 1px solid rgba(34, 211, 238, 0.2);">
          <button onclick="retryAiChatMessage(\`${escapeAttr(originalPrompt)}\`)" style="padding: 0.5rem 1rem; background: #0ea5e9; color: white; border: none; border-radius: 0.375rem; cursor: pointer; font-weight: 500; font-size: 0.875rem;">
            🔄 Retry
          </button>
        </div>`;
      }

      function retryAiChatMessage(prompt) {
        if (!prompt) return;
        const input = document.getElementById("ai-chat-input");
        if (input) {
          input.value = prompt;
          sendBuilderAiChat();
        }
      }

      async function sendBuilderAiChat() {
        if (aiChatSending) return;
        const input = document.getElementById("ai-chat-input");
        const sendBtn = document.getElementById("ai-chat-send");
        const editor = document.getElementById("builder-code-editor");
        const prompt = String(input?.value || "").trim();
        const remoteWorkflowPayload = getRemoteWorkflowAiPayload();
        if (!prompt) return;
        if ((!loggedIn || !currentUser) && !remoteWorkflowPayload.remoteRoomId) {
          // Show login required message in chat
          appendAiChatMessage({
            role: "assistant",
            html: 'You cannot access Workflow AI without logging in. <span class="ai-login-link" style="color: #4CAF50; cursor: pointer; text-decoration: underline; font-weight: 600;">Please click here to login</span>',
          });
          renderBuilderAiChat();
          // Attach click handlers to login links after rendering
          setTimeout(() => {
            document.querySelectorAll(".ai-login-link").forEach((link) => {
              link.addEventListener("click", showLogin, { once: false });
            });
          }, 0);
          if (input) input.value = "";
          return;
        }

        // SEND ALL REQUESTS TO ONLINE API
        // No local interception - let Groq API analyze intent and correct errors
        const currentCode = buildLatestAiCodeSnapshot();
        await syncAiContextSilently();

        appendAiChatMessage({ role: "user", text: prompt });
        aiChatSending = true;
        aiModelRecoveryInFlight = false;
        aiModelSwitchingInFlight = false;

        // Create abort controller for this request
        window.aiChatAbortController = new AbortController();

        if (input) input.value = "";
        if (sendBtn) {
          sendBtn.disabled = true;
          sendBtn.style.opacity = "0.6";
          sendBtn.style.pointerEvents = "none";
        }
        renderBuilderAiChat();
        try {
          setAiAgentStage("thinking");

          // Route to selected AI model
          let managerResponse;
          const isXtraAi = aiSelectedModel === "xtra";

          if (isXtraAi) {
            // Use Xtra AI (auto-selects best available model)
            try {
              managerResponse = await fetch("/api/ai/best-model", {
                method: "POST",
                credentials: "include",
                headers: { "Content-Type": "application/json" },
                body: JSON.stringify({
                  userInput: prompt,
                  currentCanvasCode: currentCode,
                  analyzeIntent: true,
                  correctErrors: true,
                  ...remoteWorkflowPayload,
                }),
                signal: window.aiChatAbortController?.signal,
              })
                .then((r) => r.json())
                .catch((err) => {
                  if (err.name === "AbortError")
                    return { success: false, aborted: true };
                  console.error("Xtra AI error:", err);
                  return {
                    success: false,
                    error: "Xtra AI temporarily unavailable",
                  };
                });

              // If request was aborted, stop processing
              if (managerResponse?.aborted) {
                aiChatSending = false;
                return;
              }

              // If Xtra AI fails, show message and fall back to Workflow AI
              if (!managerResponse?.success) {
                aiSelectedModel = "workflow";
                aiChatMessages.push({
                  role: "assistant",
                  text: `⚠️ Xtra AI unavailable. ${managerResponse?.error || "Using Workflow AI instead."}`,
                });
                renderBuilderAiChat();

                // Fall back to internal
                managerResponse = await fetch("/api/ai/manager", {
                  method: "POST",
                  credentials: "include",
                  headers: { "Content-Type": "application/json" },
                  body: JSON.stringify({
                    userInput: prompt,
                    currentCanvasCode: currentCode,
                    analyzeIntent: true,
                    correctErrors: true,
                    ...remoteWorkflowPayload,
                  }),
                  signal: window.aiChatAbortController?.signal,
                })
                  .then((r) => r.json())
                  .catch((err) => {
                    if (err.name === "AbortError")
                      return { success: false, aborted: true };
                    return { success: false };
                  });
              }
            } catch (err) {
              if (err.name === "AbortError") {
                aiChatSending = false;
                return;
              }
              console.error("Xtra AI routing error:", err);
              managerResponse = { success: false };
            }
          } else {
            // Use Internal Workflow AI (default) - with intent analysis
            managerResponse = await fetch("/api/ai/manager", {
              method: "POST",
              credentials: "include",
              headers: { "Content-Type": "application/json" },
              body: JSON.stringify({
                userInput: prompt,
                currentCanvasCode: currentCode,
                analyzeIntent: true,
                correctErrors: true,
                ...remoteWorkflowPayload,
              }),
              signal: window.aiChatAbortController?.signal,
            })
              .then((r) => r.json())
              .catch((err) => {
                if (err.name === "AbortError")
                  return { success: false, aborted: true };
                return { success: false };
              });
          }

          if (managerResponse?.aborted) {
            aiChatSending = false;
            return;
          }

          if (!managerResponse?.success) {
            // Check if there's a detailed error from the API
            const errorDetail = managerResponse?.error || managerResponse?.message;
            if (errorDetail) {
              const err = new Error("API Error");
              err.apiError = errorDetail;
              throw err;
            }
            throw new Error("AI manager failed to process request");
          }

          const hasAgentPayload = hasActionableAgentPayload(managerResponse?.formattedCommand || "");
          if (
            !isXtraAi &&
            !(managerResponse?.elementSpecs?.length > 0) &&
            !(managerResponse?.elementSpec && managerResponse?.parsedCommand) &&
            !hasAgentPayload
          ) {
            const strictWorkflowResponse =
              await requestWorkflowCommandFallback(prompt);
            if (strictWorkflowResponse?.elementSpecs?.length) {
              managerResponse = {
                ...managerResponse,
                decision: "Action",
                formattedCommand:
                  strictWorkflowResponse.formattedCommand ||
                  managerResponse?.formattedCommand,
                parsedCommands:
                  strictWorkflowResponse.parsedCommands ||
                  managerResponse?.parsedCommands ||
                  [],
                parsedCommand:
                  strictWorkflowResponse.parsedCommands?.[0] ||
                  managerResponse?.parsedCommand ||
                  null,
                elementSpecs: strictWorkflowResponse.elementSpecs,
                elementSpec:
                  strictWorkflowResponse.elementSpecs?.[0] ||
                  managerResponse?.elementSpec ||
                  null,
              };
            }
          }

          // STAGE 2: Check if we have a parsed command from Groq formatter
          if (managerResponse?.elementSpecs && managerResponse.elementSpecs.length > 0) {
            setAiAgentStage("applying");
            let insertedCount = 0;
            let lastComponentType = "";

            const canvasEl = document.getElementById("web-canvas");
            const metrics = getBuilderCanvasMetrics(canvasEl);
            const viewCenterX = metrics.scrollLeft + ((metrics.scroller.clientWidth || 300) / 2);
            const viewCenterY = metrics.scrollTop + ((metrics.scroller.clientHeight || 500) / 2);
            
            let minLeft = Infinity;
            let minTop = Infinity;
            managerResponse.elementSpecs.forEach(spec => {
              if (!spec.isBackgroundCommand && spec.styles) {
                 const l = parseFloat(spec.styles.left) || 0;
                 const t = parseFloat(spec.styles.top) || 0;
                 if (l < minLeft) minLeft = l;
                 if (t < minTop) minTop = t;
              }
            });
            if (minLeft === Infinity) minLeft = 0;
            if (minTop === Infinity) minTop = 0;

            const offsetX = Math.max(0, viewCenterX - minLeft - 150);
            const offsetY = Math.max(0, viewCenterY - minTop - 100);

            for (const spec of managerResponse.elementSpecs) {
              if (spec.styles && !spec.isBackgroundCommand) {
                const currentLeft = parseFloat(spec.styles.left) || 0;
                const currentTop = parseFloat(spec.styles.top) || 0;
                spec.styles.left = `${currentLeft + offsetX}px`;
                spec.styles.top = `${currentTop + offsetY}px`;
              }
              // Handle background image commands
              if (spec.isBackgroundCommand) {
                const target = spec.target || "body";
                const canvas = target === "body"
                  ? document.querySelector("body") || document.getElementById("builder-canvas")
                  : document.querySelector(target);

                if (canvas) {
                  Object.assign(canvas.style, spec.styles);
                  aiChatMessages.push({ role: "assistant", text: `✓ Applied background image to ${target}.` });
                }
                continue;
              }

              let insertResult;

              if (spec.isComponent) {
                if (spec.isSVG && spec.shapeType) {
                  const svgShape = generateSVGShape(spec.shapeType, spec.properties || {});
                  insertResult = applyInsertElementSpec({
                    html: svgShape.html, css: "", animations: "",
                    style: { width: svgShape.width, height: svgShape.height }, attributes: {}
                  });
                } else {
                  const componentInsertSpec = buildDeterministicInsertSpec(`insert ${spec.componentType}`, currentCode);
                  if (componentInsertSpec && componentInsertSpec.success !== false) {
                    insertResult = applyInsertElementSpec(componentInsertSpec);
                  }
                }
                lastComponentType = spec.componentType;
              } else {
                if (spec.isSVG && spec.shapeType) {
                  const svgShape = generateSVGShape(spec.shapeType, spec.properties || {});
                  insertResult = applyInsertElementSpec({
                    html: svgShape.html, css: "", animations: "",
                    style: { width: svgShape.width, height: svgShape.height }, attributes: {}
                  });
                } else {
                  insertResult = applyInsertElementSpec({
                    html: generateElementFromSpec(spec) || `<${spec.type}></${spec.type}>`,
                    css: "", animations: "",
                    style: spec.styles || {}, attributes: spec.attributes || {}
                  });
                }
                lastComponentType = spec.type;
              }

              if (insertResult && insertResult.success) {
                insertedCount++;
              }
            }

            if (insertedCount > 0) {
              syncActiveBuilderFileFromCanvas({ skipHistory: true });
              aiChatMessages.push({
                role: "assistant",
                text: `✓ Built Super Component with ${insertedCount} elements.`
              });
              setAiAgentStage("done");
              renderBuilderAiChat();
              return;
            }
          } else if (managerResponse?.elementSpec && managerResponse?.parsedCommand) {
            // Legacy single-item support
            setAiAgentStage("applying");
            const spec = managerResponse.elementSpec;

            const canvasEl = document.getElementById("web-canvas");
            if (canvasEl && spec.styles && !spec.isBackgroundCommand) {
              const metrics = getBuilderCanvasMetrics(canvasEl);
              const viewCenterX = metrics.scrollLeft + ((metrics.scroller.clientWidth || 300) / 2);
              const viewCenterY = metrics.scrollTop + ((metrics.scroller.clientHeight || 500) / 2);
              const w = parseFloat(spec.styles.width) || 300;
              const h = parseFloat(spec.styles.height) || 200;
              spec.styles.left = `${Math.max(0, viewCenterX - w/2)}px`;
              spec.styles.top = `${Math.max(0, viewCenterY - h/2)}px`;
            }

            // Handle background image commands
            if (spec.isBackgroundCommand) {
              const target = spec.target || "body";
              const canvas =
                target === "body"
                  ? document.querySelector("body") ||
                    document.getElementById("builder-canvas")
                  : document.querySelector(target);

              if (canvas) {
                // Apply background image styles
                Object.assign(canvas.style, spec.styles);
                aiChatMessages.push({
                  role: "assistant",
                  text: `✓ Applied background image (${spec.imageDescription}) to ${target}.`,
                });
              } else {
                aiChatMessages.push({
                  role: "assistant",
                  text: `⚠️ Could not find target element: ${target}`,
                });
              }

              setAiAgentStage("done");
              renderBuilderAiChat();
              return;
            }

            // Create insertion from command spec
            let insertResult;

            // NEW: Check if this is a component command
            if (spec.isComponent) {
              // Use buildDeterministicInsertSpec to handle component types
              // Check if this is an SVG shape spec
              if (spec.isSVG && spec.shapeType) {
                const svgShape = generateSVGShape(
                  spec.shapeType,
                  spec.properties || {},
                );
                insertResult = applyInsertElementSpec({
                  html: svgShape.html,
                  css: "",
                  animations: "",
                  style: {
                    width: svgShape.width,
                    height: svgShape.height,
                  },
                  attributes: {},
                });
              } else {
                const componentInsertSpec = buildDeterministicInsertSpec(
                  `insert ${spec.componentType}`,
                  currentCode,
                );
                if (
                  componentInsertSpec &&
                  componentInsertSpec.success !== false
                ) {
                  insertResult = applyInsertElementSpec(componentInsertSpec);
                } else {
                  aiChatMessages.push({
                    role: "assistant",
                    text: `⚠️ Could not recognize component type: ${spec.componentType}`,
                  });
                  setAiAgentStage("done");
                  renderBuilderAiChat();
                  return;
                }
              }
            } else {
              // Check if this is an SVG shape spec (regular element path)
              if (spec.isSVG && spec.shapeType) {
                const svgShape = generateSVGShape(
                  spec.shapeType,
                  spec.properties || {},
                );
                insertResult = applyInsertElementSpec({
                  html: svgShape.html,
                  css: "",
                  animations: "",
                  style: {
                    width: svgShape.width,
                    height: svgShape.height,
                  },
                  attributes: {},
                });
              } else {
                // Regular element spec from formatted command
                insertResult = applyInsertElementSpec({
                  html:
                    generateElementFromSpec(spec) ||
                    `<${spec.type}></${spec.type}>`,
                  css: "", // CSS already in styles
                  animations: "", // Already in styles
                  style: spec.styles || {},
                  attributes: spec.attributes || {},
                });
              }
            }

            if (insertResult.success) {
              syncActiveBuilderFileFromCanvas({ skipHistory: true });
              aiChatMessages.push({
                role: "assistant",
                text: `✓ Inserted ${spec.isComponent ? spec.componentType : spec.type} element.`,
              });
              setAiAgentStage("done");
              renderBuilderAiChat();
              return;
            }
          }

          // Fall back to original agent flow if no command spec
          const decision = managerResponse.decision;
          if (decision === "Action" || hasAgentPayload) {
            setAiAgentStage("parsing");
            let agentReply = managerResponse.formattedCommand || prompt;
            
            // Only call AI again if it doesn't already have an action payload
            if (!hasActionableAgentPayload(agentReply)) {
              agentReply = await runBuilderAiAgent(
                agentReply,
                currentCode,
                { silentUi: !isXtraAi },
              );
            }
            
            setAiAgentStage("parsing");
            let actionResult = executeAIActions(agentReply, prompt);
            const actions = actionResult?.applied || [];
            const visibleReply = stripAgentActionBlocks(agentReply);
            if (actions.length) {
              setAiAgentStage("applying");
              appendAiChatMessage(
                {
                  role: "assistant",
                  text: isXtraAi
                    ? visibleReply || "Applying changes..."
                    : `Applied ${actions.length} canvas change${actions.length === 1 ? "" : "s"}.`,
                },
                { typing: true },
              );
            } else if (isXtraAi) {
              appendAiChatMessage(
                {
                  role: "assistant",
                  text:
                    visibleReply ||
                    "Ready. Tell me what you want to build or fix next.",
                },
                { typing: true },
              );
            }
            if (actionResult?.safety?.skipped) {
              appendAiChatMessage(
                {
                  role: "assistant",
                  text:
                    actionResult.safety.message ||
                    "Skipped an unsafe action to avoid losing existing canvas work.",
                },
                { typing: true },
              );
              renderBuilderAiChat();
              // One strict retry: force non-destructive ops when the model attempted a risky replace.
              setAiAgentStage("thinking");
                const retryReply = await runBuilderAiAgent(
                  [
                    prompt,
                  "STRICT_RULE: Do NOT use UPDATE_FILE for small edits. Preserve existing canvas elements and IDs. Use UPDATE_CSS for background, MOVE_ELEMENT for position, and EDIT_CANVAS with ops[] for insert/remove/style tweaks.",
                  ]
                    .filter(Boolean)
                    .join("\n\n"),
                  currentCode,
                  { silentUi: !isXtraAi },
                );
              const retryResult = executeAIActions(retryReply, prompt);
              if (retryResult?.applied?.length) {
                appendAiChatMessage(
                  {
                    role: "assistant",
                    text: isXtraAi
                      ? stripAgentActionBlocks(retryReply) ||
                        "Applied a safer incremental patch."
                      : `Applied ${retryResult.applied.length} safer canvas change${retryResult.applied.length === 1 ? "" : "s"}.`,
                  },
                  { typing: true },
                );
                actionResult = retryResult;
              }
            }
            setAiAgentStage("implementing");
            if (actionResult?.shouldRefreshCanvas) {
              const syncResult = await forceImplementAiCanvasSync({
                allowNormalizer: true,
              });
              if (syncResult?.normalized) {
                appendAiChatMessage(
                  {
                    role: "assistant",
                    text: isXtraAi
                      ? "Canvas updated. Elements are ready for editing."
                      : "Canvas updated.",
                  },
                  { typing: true },
                );
              }
            } else {
              // Incremental ops already applied to canvas; keep it smooth (no full re-import).
              syncActiveBuilderFileFromCanvas({ skipHistory: true });
            }
          } else {
            if (isXtraAi) {
              setAiAgentStage("responding");
              const chatResponse = await runBuilderAiChatResponse(prompt);
              const visibleResponse = String(chatResponse || "").trim();
              appendAiChatMessage(
                {
                  role: "assistant",
                  text:
                    visibleResponse ||
                    "I'm here to help! What would you like to do?",
                },
                { typing: true },
              );
            } else {
              appendAiChatMessage(
                {
                  role: "assistant",
                  text:
                    "Workflow AI could not convert that request into canvas commands.",
                },
                { typing: true },
              );
            }
          }
          setAiAgentStage("done");
          renderBuilderAiChat();
        } catch (error) {
          await logErrorEvent(
            `AI chat failed: ${error.message || "unknown error"}`,
            "ai-chat",
            { promptPreview: prompt.slice(0, 160) },
          );

          // Parse error for user-friendly message
          let errorMessage;
          let isRateLimit = false;
          if (error?.apiError) {
            errorMessage = parseAiError(error.apiError);
            isRateLimit =
              error.apiError?.code === "rate_limit_exceeded" ||
              error.apiError?.error?.code === "rate_limit_exceeded" ||
              (typeof error.apiError === "string" &&
                (error.apiError.includes("rate_limit_exceeded") ||
                  error.apiError.includes("TPM")));
          } else {
            errorMessage = parseAiError(error);
            isRateLimit =
              error?.code === "rate_limit_exceeded" ||
              error?.error?.code === "rate_limit_exceeded" ||
              (typeof error === "string" &&
                (error.includes("rate_limit_exceeded") ||
                  error.includes("TPM"))) ||
              (error?.message && error.message.includes("rate_limit"));
          }

          // Add retry button for rate limit errors
          let displayHtml;
          if (isRateLimit) {
            displayHtml = `<div>${errorMessage}${createAiRetryMessage(prompt)}</div>`;
            appendAiChatMessage(
              {
                role: "assistant",
                html: displayHtml,
                text: errorMessage,
              },
              { typing: true },
            );
          } else {
            appendAiChatMessage(
              {
                role: "assistant",
                text: errorMessage,
              },
              { typing: true },
            );
          }
          setAiAgentStage("idle");
          renderBuilderAiChat();
        } finally {
          aiChatSending = false;
          if (sendBtn) {
            sendBtn.disabled = false;
            sendBtn.style.opacity = "1";
            sendBtn.style.pointerEvents = "auto";
          }
          setTimeout(() => {
            if (!aiChatSending) setAiAgentStage("idle");
          }, 900);
        }
      }

      function copyAiChatBubble(btn) {
        // Get the parent message row and find the bubble with copy text
        const messageRow = btn.closest(".ai-chat-message-row");
        if (!messageRow) return;

        const bubble = messageRow.querySelector(".ai-chat-bubble");
        if (!bubble) return;

        // Get the original text from data-copy-text attribute
        const text = String(bubble.dataset.copyText || "").trim();

        if (!text) {
          console.warn("No text to copy");
          return;
        }

        // Copy to clipboard
        if (navigator.clipboard && navigator.clipboard.writeText) {
          navigator.clipboard
            .writeText(text)
            .then(() => {
              // Show success feedback with checkmark
              const originalIcon = btn.innerHTML;
              btn.innerHTML = '<i class="fas fa-check text-[10px]"></i>';
              btn.style.opacity = "1";
              setTimeout(() => {
                btn.innerHTML = originalIcon;
              }, 1500);
            })
            .catch((err) => {
              console.error("Copy failed:", err);
              showBuilderSnackbar("Failed to copy", "error");
            });
        } else {
          // Fallback for older browsers
          const textArea = document.createElement("textarea");
          textArea.value = text;
          textArea.style.position = "fixed";
          textArea.style.opacity = "0";
          document.body.appendChild(textArea);
          textArea.select();
          try {
            document.execCommand("copy");
            const originalIcon = btn.innerHTML;
            btn.innerHTML = '<i class="fas fa-check text-[10px]"></i>';
            btn.style.opacity = "1";
            setTimeout(() => {
              btn.innerHTML = originalIcon;
            }, 1500);
          } catch (err) {
            console.error("Copy failed:", err);
            showBuilderSnackbar("Failed to copy", "error");
          }
          document.body.removeChild(textArea);
        }
      }

