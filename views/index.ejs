          }
          const res = await fetch("/api/auth/me", {
            credentials: "include",
            cache: "no-store",
            headers: { "Cache-Control": "no-store" },
          });
          const data = await res.json();
          if (data.success && data.user) {
            markSessionHealthy();
            loggedIn = true;
            currentUser = data.user;
            try {
              localStorage.setItem("medialab_has_session", "true");
            } catch {}
            await fetchPremiumRequestStatus();
            updateUserProfileUi();
            applyNotificationSnapshot(data.notifications, data.unreadCount);
            authBootstrapReady = true;
            await fetchNotifications({ allowSessionRecovery: false }).catch(
