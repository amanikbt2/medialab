        };

        // Cancel handler
        cancelBtn.onclick = () => {
          editContainer.remove();
          bubbleBody.style.display = "block";
          actionsDiv.style.display = "flex";
        };

        // Update handler - resend the edited message
        updateBtn.onclick = async () => {
          const editedText = textarea.value.trim();
          if (!editedText) return;

          if (editedText !== originalText) {
            // Update message in array
            aiChatMessages[messageIndex].text = editedText;
            aiChatMessages[messageIndex].html = null;
            aiChatMessages[messageIndex]._renderedChars = editedText.length;
            aiChatMessages[messageIndex]._typingDone = true;

            // Re-render to show updated message
            renderBuilderAiChat();
          }

          // Resend the edited message using the same logic as sendBuilderAiChat
          const currentCode = buildLatestAiCodeSnapshot();
          await syncAiContextSilently();

          // Remove the edit container
          editContainer.remove();

          aiChatSending = true;
          aiModelRecoveryInFlight = false;
          aiModelSwitchingInFlight = false;

          window.aiChatAbortController = new AbortController();

          const sendBtn = document.getElementById("ai-chat-send");
          if (sendBtn) {
            sendBtn.disabled = true;
            sendBtn.style.opacity = "0.6";
            sendBtn.style.pointerEvents = "none";
          }

          try {
            setAiAgentStage("thinking");

            let managerResponse;
            const isXtraAi = aiSelectedModel === "xtra";
            const isFirstMessage =
              aiChatMessages.filter((m) => m.role !== "system_hidden").length <=
              1;
            const userContextData = isFirstMessage
              ? {
                  userName: String(currentUser?.name || "").trim(),
                  userLocation: String(currentUser?.location || "").trim(),
                }
              : null;

            if (isXtraAi) {
              try {
                const requestBody = {
                  userInput: editedText,
                  currentCanvasCode: currentCode,
                  analyzeIntent: true,
                  correctErrors: true,
                };

                if (userContextData) {
                  requestBody.userContext = userContextData;
                }

                managerResponse = await fetch("/api/ai/best-model", {
                  method: "POST",
                  credentials: "include",
                  headers: { "Content-Type": "application/json" },
                  body: JSON.stringify(requestBody),
                  signal: window.aiChatAbortController?.signal,
                })
                  .then((r) => r.json())
                  .catch((err) => {
                    if (err.name === "AbortError")
                      return { success: false, aborted: true };
                    return {
                      success: false,
                      error: "Xtra AI temporarily unavailable",
                    };
                  });

                if (managerResponse?.aborted) {
                  aiChatSending = false;
                  return;
                }

                if (!managerResponse?.success) {
                  aiSelectedModel = "workflow";
                  aiChatMessages.push({
                    role: "assistant",
                    text: `⚠️ Xtra AI unavailable. Using Workflow AI instead.`,
                  });
                  renderBuilderAiChat();

                  managerResponse = await fetch("/api/ai/manager", {
                    method: "POST",
                    credentials: "include",
                    headers: { "Content-Type": "application/json" },
                    body: JSON.stringify({
                      userInput: editedText,
                      currentCanvasCode: currentCode,
                      analyzeIntent: true,
                      correctErrors: true,
                      ...(userContextData && { userContext: userContextData }),
                    }),
                    signal: window.aiChatAbortController?.signal,
                  })
                    .then((r) => r.json())
                    .catch((err) => {
                      if (err.name === "AbortError")
                        return { success: false, aborted: true };
                      return { success: false };
                    });
                }
              } catch (err) {
                if (err.name === "AbortError") {
                  aiChatSending = false;
                  return;
                }
                managerResponse = { success: false };
              }
            } else {
              managerResponse = await fetch("/api/ai/manager", {
                method: "POST",
                credentials: "include",
                headers: { "Content-Type": "application/json" },
                body: JSON.stringify({
                  userInput: editedText,
                  currentCanvasCode: currentCode,
                  analyzeIntent: true,
                  correctErrors: true,
                  ...(userContextData && { userContext: userContextData }),
                }),
                signal: window.aiChatAbortController?.signal,
              })
                .then((r) => r.json())
                .catch((err) => {
                  if (err.name === "AbortError")
                    return { success: false, aborted: true };
                  return { success: false };
                });
            }

            if (managerResponse?.aborted) {
              aiChatSending = false;
              if (sendBtn) {
                sendBtn.disabled = false;
                sendBtn.style.opacity = "1";
                sendBtn.style.pointerEvents = "auto";
              }
              return;
            }

            // Handle response (same as normal send flow)
            if (managerResponse?.success) {
              appendAiChatMessage({
                role: "assistant",
                text: managerResponse.content || "Response received",
                typing: true,
              });
            } else {
              appendAiChatMessage({
                role: "assistant",
                text:
                  managerResponse?.message ||
                  "Request failed. Please try again.",
              });
            }
          } catch (error) {
            console.error("Edit and resend failed:", error);
            appendAiChatMessage({
              role: "assistant",
              text: "An error occurred while resending. Please try again.",
            });
          } finally {
            aiChatSending = false;
            if (sendBtn) {
              sendBtn.disabled = false;
              sendBtn.style.opacity = "1";
              sendBtn.style.pointerEvents = "auto";
            }
            renderBuilderAiChat();
          }
        };

        // Assemble edit container
        buttonContainer.appendChild(cancelBtn);
        buttonContainer.appendChild(updateBtn);
        editContainer.appendChild(textarea);
        editContainer.appendChild(buttonContainer);

        // Replace bubble content with edit container
        bubbleBody.style.display = "none";
        actionsDiv.style.display = "none";
        bubble.appendChild(editContainer);

        // Focus textarea
        textarea.focus();
        textarea.select();
      }

      function stopBuilderAiChat() {
        // Stop the AI processing
        aiChatSending = false;
        aiModelRecoveryInFlight = false;
        aiModelSwitchingInFlight = false;
        stopAiChatTyping();

        // Abort any pending fetch requests
        if (window.aiChatAbortController) {
          window.aiChatAbortController.abort();
          window.aiChatAbortController = null;
        }

        // Reset the agent stage to idle
        setAiAgentStage("idle");

        // Add a message indicating the AI was stopped
        aiChatMessages.push({
          role: "assistant",
          text: "⏹️ AI processing stopped.",
        });

        // Update the button state
        const sendBtn = document.getElementById("ai-chat-send");
        const stopBtn = document.getElementById("ai-chat-stop");
        if (sendBtn) {
          sendBtn.disabled = false;
          sendBtn.style.opacity = "1";
          sendBtn.style.pointerEvents = "auto";
        }
        if (stopBtn) {
          stopBtn.classList.add("hidden");
        }

        // Re-render the chat
        renderBuilderAiChat();

        // Show feedback
        showBuilderSnackbar("AI processing stopped", "info");
      }

      async function triggerMagicFix() {
        if (aiMagicFixRunning) return;
        if (!loggedIn || !currentUser) {
          showLogin();
          return;
        }
        const editor = document.getElementById("builder-code-editor");
        const canvas = document.getElementById("web-canvas");
        const magicBtn = document.getElementById("btn-magic-fix");
        const magicIcon = document.getElementById("magic-fix-icon");
        const code = buildCodeModeDocument();
        if (!String(code || "").trim()) {
          showBuilderSnackbar(
            "No canvas code found for Magic Auto-Fix.",
            "error",
          );
          return;
        }
        aiMagicFixRunning = true;
        aiModelRecoveryInFlight = false;
        aiModelSwitchingInFlight = false;
        if (canvas) canvas.classList.add("magic-fix-active");
        if (magicBtn) {
          magicBtn.disabled = true;
          magicBtn.classList.add("magic-fix-running");
        }
        if (magicIcon) magicIcon.classList.add("is-spinning");

        // Model fallback list for auto-retry
        const modelsToTry = [
          "openai/gpt-oss-120b",
          "llama-3.3-70b-versatile",
          "openai/gpt-oss-20b",
          "meta-llama/llama-4-scout-17b-16e-instruct",
          "groq/compound",
        ];
        let lastError = null;
        let successfulModel = null;

        try {
          for (
            let modelIndex = 0;
            modelIndex < modelsToTry.length;
            modelIndex++
          ) {
            const modelId = modelsToTry[modelIndex];
            try {
              // Show which model is being attempted
              let retryTaskId = null;
              if (modelIndex > 0) {
                showBuilderSnackbar(
                  `Autofix failed, trying ${modelId}...`,
                  "warn",
                );
                retryTaskId = addAIThinkingTask(`Retrying with ${modelId}...`);
              }

              const res = await fetch("/api/ai/autofix", {
                method: "POST",
                credentials: "include",
                headers: { "Content-Type": "application/json" },
                body: JSON.stringify({
                  currentCode: code,
                  preferredModel: modelId, // Request specific model
                }),
              });
              const data = await res.json().catch(() => ({}));

              // Complete the retry task
              if (retryTaskId) {
                completeAIThinkingTask(retryTaskId, 0);
              }

              if (!res.ok || !data.success) {
                if (data.limitReached) {
                  openUpgradeModal();
                  showBuilderSnackbar(
                    "Daily Auto-Fix credits reached. Upgrade to Pro.",
                    "error",
                  );
                  return;
                }
                lastError = data.message || `${modelId} failed`;
                continue; // Try next model
              }

              // SUCCESS: This model worked
              successfulModel = modelId;
              aiActiveModel = String(data.modelUsed || modelId);
              if (data.modelRecoveryUsed) aiModelRecoveryInFlight = true;
              if (
                data.modelSwitchUsed &&
                data.modelSwitchReason === "rate_limit"
              ) {
                aiModelSwitchingInFlight = true;
                aiChatMessages.push({
                  role: "assistant",
                  text: "Choosing the best model for your response...",
                });
                renderBuilderAiChat();
              }
              if (data.creditsRemaining !== undefined)
                aiCreditsRemaining = data.creditsRemaining;
              if (editor) {
                editor.value = String(data.updatedCode || "");
                handleBuilderCodeInput();
              }
              applyCodeModeToCanvas();

              // Show success message
              const successMsg =
                modelIndex > 0
                  ? `Magic Auto-Fix recovered with ${aiActiveModel} ✓`
                  : `Magic Auto-Fix applied successfully with ${aiActiveModel}.`;
              aiChatMessages.push({
                role: "assistant",
                text: successMsg,
              });
              renderBuilderAiChat();
              showBuilderSnackbar(successMsg, "success");
              break; // Exit loop on success
            } catch (modelError) {
              lastError = modelError.message;
              // Continue to next model
            }
          }

          // If all models failed
          if (!successfulModel) {
            throw new Error(
              lastError ||
                "Autofix failed on all available models. Please try again.",
            );
          }
        } catch (error) {
          await logErrorEvent(
            `Magic Auto-Fix failed: ${error.message || "unknown error"}`,
            "ai-autofix",
            {
              promptPreview: String(code || "").slice(0, 160),
              modelsAttempted: modelsToTry.length,
            },
          );
          showBuilderSnackbar(
            `⚠️ Autofix failed: ${error.message || "Unable to fix code."}`,
            "error",
          );
        } finally {
          aiMagicFixRunning = false;
          if (canvas) canvas.classList.remove("magic-fix-active");
          if (magicBtn) {
            magicBtn.disabled = false;
            magicBtn.classList.remove("magic-fix-running");
          }
          if (magicIcon) magicIcon.classList.remove("is-spinning");
          const editor = document.getElementById("builder-code-editor");
          if (editor) editor.classList.remove("magic-blur-preparing");
        }
      }
      let autoFixBlurThrottleTimer = null;
      let autoFixBlurLastTrigger = 0;
      function triggerSmartMagicAutoFix() {
        const now = Date.now();
        if (now - autoFixBlurLastTrigger < 2000) return;
        autoFixBlurLastTrigger = now;
        const editor = document.getElementById("builder-code-editor");
        if (!editor || !editor.value?.trim()) return;
        if (aiMagicFixRunning) return;
        editor.classList.add("magic-blur-preparing");
        clearTimeout(autoFixBlurThrottleTimer);
        autoFixBlurThrottleTimer = setTimeout(async () => {
          if (editor.classList.contains("magic-blur-preparing")) {
            editor.classList.remove("magic-blur-preparing");
            const magicBtn = document.getElementById("btn-magic-fix");
            if (magicBtn && !magicBtn.disabled) {
              magicBtn.click();
            }
          }
        }, 480);
      }
      window.addEventListener("error", (event) => {
        const message = String(event?.message || "").trim();
        if (!message) return;
        logErrorEvent(`Unhandled error: ${message}`, "client-runtime", {
          filename: String(event?.filename || ""),
          line: Number(event?.lineno || 0),
          column: Number(event?.colno || 0),
        });
      });
      window.addEventListener("unhandledrejection", (event) => {
        const reasonText = String(
          event?.reason?.message || event?.reason || "",
        ).trim();
        if (!reasonText) return;
        logErrorEvent(`Unhandled rejection: ${reasonText}`, "client-runtime");
      });
      function refreshBuilderCodeMode() {
        const editor = document.getElementById("builder-code-editor");
        const highlight = document.getElementById("builder-code-highlight");
        const lineGutter = document.getElementById("builder-code-lines");
        if (!editor) return;
        editor.value = getBuilderEditorDocument();
        if (highlight) highlight.innerHTML = highlightBuilderCode(editor.value);
        if (lineGutter)
          lineGutter.textContent = buildCodeLineNumbers(editor.value);
        syncCodeEditorScroll();
        syncBuilderCodeFileLabel();
      }
      function buildCodeLineNumbers(code = "") {
        const lineCount = Math.max(1, code.split("\n").length);
        return Array.from({ length: lineCount }, (_, index) =>
          String(index + 1),
        ).join("\n");
      }
      function escapeCodeHtml(value = "") {
        return value
          .replace(/&/g, "&amp;")
          .replace(/</g, "&lt;")
          .replace(/>/g, "&gt;");
      }
      function highlightBuilderCode(code = "") {
        let html = escapeCodeHtml(code);
        html = html.replace(
          /(&lt;!--[\s\S]*?--&gt;)/g,
          '<span class="code-token-comment">$1</span>',
        );
        html = html.replace(
          /(&lt;!doctype)(.*?&gt;)/gi,
          '<span class="code-token-doctype">$1$2</span>',
        );
        html = html.replace(
          /(&lt;\/?)([a-zA-Z0-9-]+)/g,
