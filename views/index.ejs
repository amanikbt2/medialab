      async function handleVideoSelection(file) {
        if (!file) return;
        const progressDiv = document.getElementById("universal-progress");
        const statusText = document.getElementById("universal-status-text");
        const bar = document.getElementById("universal-bar");
        const convertBtn = document.getElementById("convert-btn");
        // 1. Show Universal Progress immediately
        progressDiv.classList.remove("hidden");
        statusText.innerText = "Uploading Video to Server...";
        bar.style.width = "10%";
        // 2. Prepare Form Data
        const formData = new FormData();
        formData.append("file", file);
        try {
          // USE RELATIVE PATH: Render handles the domain automatically
          const response = await fetch("/api/upload", {
            method: "POST",
            body: formData,
          });
          if (!response.ok) throw new Error("Upload Failed");
          const result = await response.json();
          if (result.success) {
            selectedVideoFile = result.filename; // Store for the next step
            // 3. Update UI to "Ready" state
            statusText.innerText = "Upload Complete. Ready to Extract.";
            bar.style.width = "100%";
            bar.classList.replace("bg-cyan-500", "bg-green-500");
            if (convertBtn) convertBtn.disabled = false;
            // Hide progress after 2 seconds so user sees the "Extract" button
            setTimeout(() => {
              progressDiv.classList.add("hidden");
              bar.style.width = "0%";
              bar.classList.replace("bg-green-500", "bg-cyan-500");
            }, 2000);
            // Show the file info display if it exists in your tool HTML
            const infoDisplay = document.getElementById("video-info-display");
            const nameLabel = document.getElementById("file-name-label");
            if (infoDisplay) infoDisplay.classList.remove("hidden");
            if (nameLabel) nameLabel.innerText = file.name;
            // Hide the drop zone
            const dropZone = document.getElementById("drop-zone-video");
            if (dropZone) dropZone.classList.add("hidden");
          }
        } catch (err) {
          console.error("Upload Error:", err);
          statusText.innerText = "Error: File too large or connection lost.";
          bar.classList.replace("bg-cyan-500", "bg-red-500");
          alert("Video upload failed. Ensure the file is under 100MB.");
        }
