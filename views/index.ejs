            .forEach((part) => {
              const lines = part.split("\n").map((line) => line.trimEnd());
              const bulletLines = lines.filter((line) =>
                /^[-*]\s+/.test(line.trim()),
              );
              const orderedLines = lines.filter((line) =>
                /^\d+\.\s+/.test(line.trim()),
              );
