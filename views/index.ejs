      function createDefaultBuilderProjectFiles() {
        return {
          name: "root",
          type: "folder",
          children: [
            {
              name: "index.html",
              type: "file",
              content: "",
              links: { cssLinks: [], jsLinks: [] },
            },
          ],
        };
      }
      function normalizeBuilderFilePath(path = "") {
        return String(path || "")
          .replace(/\\/g, "/")
          .replace(/^\/+/, "")
          .replace(/\/+/g, "/")
          .trim();
      }
      function getBuilderFileExtension(path = "") {
        const normalized = normalizeBuilderFilePath(path);
        const dotIndex = normalized.lastIndexOf(".");
        return dotIndex >= 0
          ? normalized.slice(dotIndex + 1).toLowerCase()
          : "";
      }
      function isBuilderHtmlFile(path = "") {
        return ["html", "htm", "ejs"].includes(getBuilderFileExtension(path));
      }
      function isBuilderCodeOnlyFile(path = "") {
        return ["css", "js"].includes(getBuilderFileExtension(path));
      }
      function splitBuilderFilePath(path = "") {
        return normalizeBuilderFilePath(path)
          .split("/")
          .map((part) => String(part || "").trim())
          .filter(Boolean);
      }
      function cloneBuilderProjectFiles(node = null) {
        return node
          ? JSON.parse(JSON.stringify(node))
          : createDefaultBuilderProjectFiles();
      }
      function ensureBuilderProjectFiles() {
        if (!builderProjectFiles || builderProjectFiles.type !== "folder") {
          builderProjectFiles = createDefaultBuilderProjectFiles();
        }
        const hasIndex = Array.isArray(builderProjectFiles.children)
          ? builderProjectFiles.children.some(
              (child) =>
                child?.type === "file" &&
                String(child?.name || "")
                  .trim()
                  .toLowerCase() === "index.html",
            )
          : false;
        if (!hasIndex) {
          builderProjectFiles.children = Array.isArray(
            builderProjectFiles.children,
          )
            ? builderProjectFiles.children
            : [];
          builderProjectFiles.children.unshift({
            name: "index.html",
            type: "file",
            content: "",
            links: { cssLinks: [], jsLinks: [] },
          });
        }
        return builderProjectFiles;
      }
      function normalizeBuilderFileLinks(links = {}) {
        const toList = (value) =>
          (Array.isArray(value) ? value : [])
            .map((item) => String(item || "").trim())
            .filter(Boolean);
        return {
          cssLinks: toList(links.cssLinks),
          jsLinks: toList(links.jsLinks),
        };
      }
      function findBuilderNodeByPath(
        path = "",
        node = ensureBuilderProjectFiles(),
        currentPath = "",
      ) {
        const normalized = normalizeBuilderFilePath(path);
        if (!normalized) return node;
        const nodePath = normalizeBuilderFilePath(currentPath);
        if (nodePath === normalized) return node;
        if (node?.type !== "folder") return null;
        const children = Array.isArray(node.children) ? node.children : [];
        for (const child of children) {
          const childPath = normalizeBuilderFilePath(
            nodePath ? `${nodePath}/${child.name}` : child.name,
          );
          if (childPath === normalized) return child;
          if (child.type === "folder") {
            const nested = findBuilderNodeByPath(normalized, child, childPath);
            if (nested) return nested;
          }
        }
        return null;
      }
      function updateBuilderFileContent(path = "", content = "") {
        const node = findBuilderNodeByPath(path);
        if (!node || node.type !== "file") return;
        node.content = String(content || "");
      }
      function getBuilderFileLinks(path = "") {
        const node = findBuilderNodeByPath(path);
        if (!node || node.type !== "file") {
          return { cssLinks: [], jsLinks: [] };
        }
        node.links = normalizeBuilderFileLinks(node.links || {});
        return node.links;
      }
      function updateBuilderFileLinks(path = "", links = {}) {
        const node = findBuilderNodeByPath(path);
        if (!node || node.type !== "file") return;
        node.links = normalizeBuilderFileLinks(links);
      }
      function getBuilderFolderNode(path = "") {
        const normalized = normalizeBuilderFilePath(path);
        if (!normalized) return ensureBuilderProjectFiles();
