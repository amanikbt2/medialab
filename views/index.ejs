          const hasWidth = /width\s*:/.test(style);
          const hasHeight = /height\s*:/.test(style);
          const hasPosition = /position\s*:/.test(style);
          let newStyle = style;
          if (!hasPosition) {
            newStyle = "position: absolute; " + newStyle;
          }
          if (!hasLeft) {
            const rect = el.getBoundingClientRect();
            newStyle = newStyle + `; left: ${Math.round(rect.left || 0)}px`;
          }
          if (!hasTop) {
            const rect = el.getBoundingClientRect();
            newStyle = newStyle + `; top: ${Math.round(rect.top || 0)}px`;
