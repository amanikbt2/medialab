      function validateWithdrawalForm() {
        clearWithdrawErrors();
        const balance = getCurrentBalance();
        const destination = String(
          document.getElementById("withdraw-destination-input")?.value || "",
        ).trim();
        const amount = Number(
          document.getElementById("withdraw-amount-input")?.value || 0,
        );
        if (!selectedWithdrawalMethod) {
          showWithdrawError("Select a withdrawal method first.");
          return null;
        }
        if (!destination) {
          showWithdrawError("Enter your payout destination.");
          return null;
        }
        if (
          selectedWithdrawalMethod === "paypal" &&
          !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(destination)
        ) {
          showWithdrawError("Enter a valid PayPal email address.");
          return null;
        }
        if (
          (selectedWithdrawalMethod === "mpesa" ||
            selectedWithdrawalMethod === "airtel") &&
          !/^\+?[0-9]{9,15}$/.test(destination.replace(/\s+/g, ""))
        ) {
          showWithdrawError("Enter a valid phone number with country code.");
          return null;
        }
        if (!Number.isFinite(amount) || amount < 5) {
          showWithdrawError("Minimum withdrawal is $5.");
          return null;
        }
        if (amount > balance) {
          showWithdrawError(
            "Withdrawal amount cannot exceed your available balance.",
          );
          return null;
        }
        return {
          method: selectedWithdrawalMethod,
          destination,
          amount: Number(amount.toFixed(2)),
          fee: 0,
        };
      }
