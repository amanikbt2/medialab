        ) {
          const templateCode = String(
            marketplaceDraftListing.sourceHtml || "",
          ).trim();
          marketplaceDraftListing = {
            ...marketplaceDraftListing,
            price: 0,
            category:
              String(marketplaceDraftListing.category || "").trim() ||
