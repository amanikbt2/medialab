      // Format function
      function format(command, value = null) {
        const editor = document.getElementById("text-input");
        if (!editor) return;
        editor.focus();
        if (command === "fontSize") {
          // Map the 1-7 selector to actual CSS pixel strings
          const sizeMap = {
            1: "12px",
            2: "14px",
            3: "16px",
            4: "18px",
            5: "24px",
            6: "32px",
          };
          const pixelSize = sizeMap[value] || "16px";
          // Apply as a span with a style attribute instead of a <font> tag
          document.execCommand(
            "insertHTML",
            false,
            `<span style="font-size: ${pixelSize};">${window.getSelection()}</span>`,
          );
        } else {
          document.execCommand(command, false, value);
