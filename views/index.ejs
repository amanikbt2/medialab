        backdrop-filter: blur(26px);
        box-shadow: 0 30px 90px rgba(2, 6, 23, 0.52);
        transform: translateY(calc(100% + 1rem));
        opacity: 0;
        pointer-events: none;
        transition:
          transform 0.28s ease,
          opacity 0.22s ease;
