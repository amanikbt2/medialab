          const res = await fetch("/api/notifications", {
            credentials: "include",
            cache: "no-store",
            headers: { "Cache-Control": "no-store" },
          });
          const data = await res.json();
          if (res.status === 401) {
            if (allowSessionRecovery) {
              const sessionRecovered = await syncServerSessionState({
                silent: true,
              }).catch(() => false);
              if (sessionRecovered && loggedIn && currentUser) {
                return fetchNotifications({ allowSessionRecovery: false });
              }
            }
            await handleAuthSessionFailure(
              data.message || "Your session ended. Please sign in again.",
