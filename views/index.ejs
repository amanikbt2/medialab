                    <svg class="ml-spinner-svg" viewBox="0 0 50 50" style="width: 40px; height: 40px; animation: ml-spin 1s linear infinite;">
                      <circle cx="25" cy="25" r="20" fill="none" stroke="${color}" stroke-width="3" stroke-dasharray="31.4 94.2" stroke-linecap="round"/>
                    </svg>
