      function getActiveInspectorPages() {
        return inspectorMode === "keyframes"
          ? inspectorAnimationPages
          : inspectorPages;
      }
      function setInspectorMode(mode = "css") {
        inspectorMode = mode === "keyframes" ? "keyframes" : "css";
        inspectorPageIndex = 0;
        document
          .getElementById("inspector-mode-css")
          ?.classList.toggle("active", inspectorMode === "css");
        document
          .getElementById("inspector-mode-keyframes")
          ?.classList.toggle("active", inspectorMode === "keyframes");
        syncInspectorUI(true);
      }
      function renderInspectorAnimationControls(styles) {
        const s = normalizeBuilderStyles(styles, currentInspectorState.type);
        let h = `<div class="space-y-3">`;
        const pageKey =
          inspectorAnimationPages[inspectorPageIndex] || "Opacity";
        const presetOptions =
          pageKey === "Opacity"
            ? inspectorAnimationPresets.opacity
            : pageKey === "Color"
              ? inspectorAnimationPresets.color
              : pageKey === "Transform"
                ? inspectorAnimationPresets.transform
                : inspectorAnimationPresets.motion;
