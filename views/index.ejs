        try {
          const res = await fetch("/api/community-feedback", {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            credentials: "include",
            body: JSON.stringify({
              rating: feedbackRating,
              feedback: feedbackText,
              source: "web-builder",
