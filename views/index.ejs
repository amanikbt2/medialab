        const column = hash % 4;
        const row = Math.floor(hash / 4) % 3;
        const left = Math.max(
          12,
          Math.min(window.innerWidth - 236, 20 + column * 178),
        );
        const top = Math.max(
          112,
          Math.min(window.innerHeight - 96, 132 + row * 92),
        );
        return { left, top };
      }
