        );
        const projectName =
          rootFolder.replace(/\/$/, "").split("/").pop() ||
          preferredHtml.file.name.replace(/\.html?$/i, "") ||
          "Imported Project";
        const buildVfsDisplayPath = (rawPath = "") => {
          const normalizedOriginalPath = normalizeImportedProjectPath(rawPath);
          if (!normalizedOriginalPath) return "";
          if (normalizedFiles.length === 1) {
            const singleFolderName =
              preferredHtml.file.name.replace(/\.html?$/i, "") ||
              projectName ||
              "Imported Project";
            return `${normalizeImportedProjectPath(singleFolderName)}/index.html`;
          }
          return normalizedOriginalPath;
        };
        const filesForPublish = await Promise.all(
          normalizedFiles.map(async ({ file, path }) => {
            const relativePath = makeProjectRelative(path);
            return {
              path: relativePath,
              contentBase64: await new Promise((resolve, reject) => {
                const reader = new FileReader();
                reader.onload = () =>
                  resolve(
                    String(reader.result || "")
                      .split(",")
                      .pop() || "",
                  );
                reader.onerror = reject;
                reader.readAsDataURL(file);
              }),
              mimeType: file.type || "",
            };
          }),
        );
        const vfsEntries = await Promise.all(
          normalizedFiles.map(async ({ file, path }) => {
            const displayPath = buildVfsDisplayPath(path);
            const lower = String(displayPath || "").toLowerCase();
            const isTextFile = /\.(html?|css|js|json|txt|md)$/i.test(lower);
            return {
              path: displayPath,
              content: isTextFile ? await file.text() : "",
            };
          }),
        );
        if (progressDiv && statusText && bar && percentLabel) {
          statusText.innerText = "Project ready.";
          bar.classList.remove("bg-cyan-400");
          bar.classList.add("bg-green-500");
          bar.style.width = "100%";
          percentLabel.innerText = "100%";
          setTimeout(() => {
            progressDiv.classList.add("hidden");
            bar.style.width = "0%";
            bar.classList.remove("bg-green-500");
            bar.classList.add("bg-cyan-400");
            percentLabel.innerText = "0%";
          }, 1800);
        }
        return {
          projectName,
          sourceHtml: htmlText,
          rootHtml: rewrittenHtml,
          entryPath: makeProjectRelative(preferredHtml.path) || "index.html",
          vfsEntryPath: buildVfsDisplayPath(preferredHtml.path) || "index.html",
          files: filesForPublish,
          vfsEntries,
          rootFolder,
          assetMap,
          resolvedCssMap,
          skippedFilesCount,
        };
      }
