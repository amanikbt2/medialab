      function initBuilderCanvasWorkspaceAutoSize() {
        const canvas = document.getElementById("web-canvas");
        const container = document.getElementById("canvas-container");
        if (!canvas || !container) return;
        requestBuilderCanvasWorkspaceSize();
        if (!builderCanvasMutationObserver) {
          builderCanvasMutationObserver = new MutationObserver(() => {
            requestBuilderCanvasWorkspaceSize();
          });
          builderCanvasMutationObserver.observe(canvas, {
            childList: true,
            subtree: true,
            attributes: true,
            attributeFilter: ["style", "class"],
          });
        }
        if (
          !builderCanvasResizeObserver &&
          typeof ResizeObserver === "function"
        ) {
          builderCanvasResizeObserver = new ResizeObserver(() => {
            requestBuilderCanvasWorkspaceSize();
          });
          builderCanvasResizeObserver.observe(canvas);
          builderCanvasResizeObserver.observe(container);
        }
        window.addEventListener("resize", requestBuilderCanvasWorkspaceSize);
      }
