      function applyCustomListStyle(style) {
        const editor = document.getElementById("text-input");
        if (!editor) return;
        editor.focus();
        // 1. Map your shorthand to valid CSS list-style-type values
        const styleMap = {
          1: "decimal",
          a: "lower-alpha",
          A: "upper-alpha",
          i: "lower-roman",
          I: "upper-roman",
          disc: "disc",
          circle: "circle",
          square: "square",
        };
        const cssStyle = styleMap[style] || style;
        const isOrdered = [
          "decimal",
          "lower-alpha",
          "upper-alpha",
          "lower-roman",
          "upper-roman",
        ].includes(cssStyle);
        // 2. Apply the basic list structure first (handles the multi-line conversion)
        document.execCommand(
          isOrdered ? "insertOrderedList" : "insertUnorderedList",
          false,
          null,
        );
        // 3. Professional Selection Logic: Apply the specific style to all lists in the selection
        setTimeout(() => {
          const selection = window.getSelection();
          if (!selection.rangeCount) return;
          const range = selection.getRangeAt(0);
          // Create a temporary container to find all UL/OL within the selected range
          const container = range.commonAncestorContainer;
          const parentElement =
            container.nodeType === 1 ? container : container.parentElement;
          // Find all lists that might be part of the selection
          const lists = parentElement.querySelectorAll(isOrdered ? "ol" : "ul");
          lists.forEach((list) => {
            // Only style the list if it's within or part of the selection
            if (selection.containsNode(list, true)) {
              list.style.listStyleType = cssStyle;
              list.style.listStylePosition = "outside";
              // Ensure Tailwind doesn't override this
              list.setAttribute(
                "style",
                `list-style-type: ${cssStyle} !important; padding-left: 1.5rem;`,
              );
            }
          });
          // Close menu and save
          const menu = document.getElementById("list-style-menu");
          if (menu) menu.classList.add("hidden");
          updateToolbarState();
          saveHistory();
        }, 10);
