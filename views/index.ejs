      /**
       * Generate HTML element from Groq-formatted command spec
       * Converts element type and properties to production-ready HTML
       * Includes content, styles, and attributes
       */
      function generateElementFromSpec(spec = {}) {
        const {
          type,
          label,
          styles = {},
          content = null,
          attributes = {},
        } = spec;

        if (!type) return null;

        // Convert styles object to inline style string
        const styleString = Object.entries(styles)
          .map(([key, value]) => `${key}:${value}`)
          .join(";");

        // Convert attributes object to string
        const attrString = Object.entries(attributes)
          .map(([key, value]) => `${key}="${value}"`)
          .join(" ");

        // Generate appropriate element based on type
        let html = "";
        const contentText = content || "Sample Text";

        switch (type.toLowerCase()) {
          case "button":
            html = `<button ${attrString} style="${styleString}">${contentText}</button>`;
            break;
          case "input":
            html = `<input type="text" ${attrString} style="${styleString}" placeholder="${contentText}">`;
            break;
          case "checkbox":
            html = `<input type="checkbox" ${attrString} style="${styleString}">`;
            break;
          case "radio":
            html = `<input type="radio" ${attrString} style="${styleString}">`;
            break;
          case "color":
            html = `<input type="color" value="${contentText || "#3b82f6"}" ${attrString} style="${styleString}">`;
            break;
          case "range":
          case "slider":
            html = `<input type="range" min="0" max="100" value="50" ${attrString} style="${styleString}">`;
            break;
          case "toggle":
          case "switch":
            html = `<label style="position: relative; display: inline-flex; cursor: pointer; ${styleString}"><input type="checkbox" style="display: none;" ${attrString}><span style="position: relative; display: inline-block; width: 56px; height: 32px; background-color: #ccc; border-radius: 32px; transition: 0.3s;"></span></label>`;
            break;
          case "spinner":
          case "loader":
            html = `<div style="display: flex; align-items: center; justify-content: center; ${styleString}"><svg viewBox="0 0 50 50" style="width: 40px; height: 40px; animation: spin 1s linear infinite;"><circle cx="25" cy="25" r="20" fill="none" stroke="currentColor" stroke-width="3" stroke-dasharray="31.4 94.2" stroke-linecap="round"/></svg></div>`;
            break;
          case "image":
          case "img":
            let imgSrc = "https://via.placeholder.com/300x200";
            if (styles.src || styles.image || styles.url) {
               const rawSrc = String(styles.src || styles.image || styles.url).trim();
               if (rawSrc.startsWith("http") || rawSrc.startsWith("data:")) {
                  imgSrc = rawSrc;
               } else {
                  // Fallback to pollinations if it's just a descriptive prompt
                  imgSrc = `https://image.pollinations.ai/prompt/${encodeURIComponent(rawSrc)}?width=800&height=800&nologo=true`;
               }
               // Remove from styles so it doesn't break CSS
               delete styles.src;
               delete styles.image;
               delete styles.url;
            }
            // Re-generate styleString because we mutated styles
            const updatedStyleString = Object.entries(styles)
               .map(([key, value]) => `${key}:${value}`)
               .join(";");
            html = `<img src="${imgSrc}" ${attrString} style="${updatedStyleString}" alt="${contentText}">`;
            break;
          case "h1":
          case "h2":
          case "h3":
          case "heading":
          case "title":
            html = `<h3 ${attrString} style="${styleString}">${contentText}</h3>`;
            break;
          case "text":
          case "p":
            html = `<p ${attrString} style="${styleString}">${contentText}</p>`;
            break;
          default:
            // Generic container with content if provided
            html = content
              ? `<div ${attrString} style="${styleString}">${contentText}</div>`
              : `<div ${attrString} style="${styleString}"></div>`;
        }

        return html;
      }

