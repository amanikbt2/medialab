          const componentSpec = generateRealElementHTML("modal", { color });
          if (componentSpec) {
            return {
              type: "div",
              label: "modal",
              html: componentSpec.html,
              css: componentSpec.css,
              styles: {
                width: componentSpec.width,
                height: componentSpec.height,
              },
            };
          }
        }

        // Now try complex parsing for everything else
        const complexSpec = parseComplexInsertDescription(text);
        if (complexSpec) return complexSpec;

        // NEW EXPANDED ELEMENT TYPES - Handle sliders, toggles, spinners, modals, etc.

        /**
         * Generate real professional HTML for complex interactive elements
         * Not just divs - actual functional components!
         */
