      async function fetchNotificationsWithRetry(attempts = 3, delayMs = 900) {
        let lastResult = [];
        for (
          let attempt = 0;
          attempt < Math.max(1, Number(attempts || 1));
          attempt += 1
        ) {
          lastResult = await fetchNotifications().catch(() => []);
          if (Array.isArray(lastResult) && lastResult.length > 0) {
            return lastResult;
          }
          if (Number(unreadNotificationCount || 0) > 0) {
            return lastResult;
          }
          if (attempt < Number(attempts || 1) - 1) {
            await new Promise((resolve) => setTimeout(resolve, delayMs));
          }
        }
        return lastResult;
