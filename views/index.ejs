          type: type,
          targetEl: existingEl,
          styles: existingEl
            ? normalizeBuilderStyles(extractStyles(existingEl), type)
            : normalizeBuilderStyles({}, type),
          attributes: existingEl
            ? {
                id: existingEl.id,
                text:
                  (editableDivText
                    ? existingEl
                        .querySelector(".element-body > :not(.canvas-element)")
                        ?.innerText?.trim()
                    : existingEl
                        .querySelector(".element-body")
                        ?.innerText?.trim()) ||
                  getDefaultElementAttributes(type).text ||
