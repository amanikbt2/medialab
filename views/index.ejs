      function parseWorkflowBuilderCommand(commandText = "") {
        const text = String(commandText || "").trim();
        if (!text) return null;

        if (text.startsWith("update-background")) {
          const properties = {};
          let imageDescription = "";
          let target = "body";
          let backgroundValue = "";
          text
            .split(";")
            .map((part) => part.trim())
            .filter(Boolean)
            .forEach((part) => {
              const eqIndex = part.indexOf("=");
              if (eqIndex === -1) return;
              const key = part.slice(0, eqIndex).trim().toLowerCase();
              const value = part.slice(eqIndex + 1).trim();
              if (key === "target") target = value.toLowerCase();
              else if (key === "image") imageDescription = value;
              else if (key === "background" || key === "color")
                backgroundValue = value;
              else properties[key] = value;
            });
          if (!imageDescription && !backgroundValue) return null;
          return {
            type: "update-background",
            target,
            imageDescription,
            backgroundValue,
            properties,
            rawCommand: text,
          };
        }

        const svgMatch = text.match(/^insert\s+svg:(\w+(?:-\w+)*)(.*)$/i);
        if (svgMatch) {
          const [, shapeType, propsString] = svgMatch;
          const properties = {};
          propsString
            .split(";")
            .map((part) => part.trim())
            .filter(Boolean)
            .forEach((part) => {
              const colonIndex = part.indexOf(":");
              if (colonIndex === -1) return;
              const key = part.slice(0, colonIndex).trim();
              const value = part.slice(colonIndex + 1).trim();
              if (key && value) properties[key] = value;
            });
          return {
            type: "insert-svg",
            shapeType: String(shapeType || "").toLowerCase(),
            properties,
            rawCommand: text,
          };
        }

        const componentMatch = text.match(
          /^insert\s+component:(\w+(?:-\w+)*)(.*)$/i,
        );
        if (componentMatch) {
          const [, componentType, extras] = componentMatch;
          return {
            type: "insert-component",
            componentType: String(componentType || "").toLowerCase(),
            extras: String(extras || "").trim(),
            rawCommand: text,
          };
        }

        const insertMatch = text.match(/^insert\s+(\w+)\s*(.*)$/i);
        if (!insertMatch) return null;

        const [, elementType, propertiesString] = insertMatch;
        const properties = {};
        let content = null;
        const contentMatch = String(propertiesString || "").match(
          /content="([^"]*)"/i,
        );
        if (contentMatch) content = contentMatch[1];
        String(propertiesString || "")
          .split(";")
          .map((part) => part.trim())
          .filter((part) => part && !/^content=/i.test(part))
          .forEach((part) => {
            const colonIndex = part.indexOf(":");
            if (colonIndex === -1) return;
            const key = part.slice(0, colonIndex).trim();
            const value = part.slice(colonIndex + 1).trim();
            if (key && value) properties[key] = value;
          });

        return {
          type: "insert",
          elementType: String(elementType || "").toLowerCase(),
          properties,
          content,
          rawCommand: text,
        };
      }

      function workflowCommandToElementSpec(parsed = {}) {
        if (!parsed || !parsed.type) return null;

        if (parsed.type === "update-background") {
          const styles = { ...(parsed.properties || {}) };
          if (parsed.imageDescription) {
            styles["background-image"] = `url('https://image.pollinations.ai/prompt/${encodeURIComponent(parsed.imageDescription)}?width=1920&height=1080&nologo=true')`;
            styles["background-size"] = styles["background-size"] || "cover";
            styles["background-position"] =
              styles["background-position"] || "center";
            styles["background-repeat"] =
              styles["background-repeat"] || "no-repeat";
          } else if (parsed.backgroundValue) {
            styles.background = parsed.backgroundValue;
          }
          return {
            type: "background",
            target: parsed.target || "body",
            styles,
            imageDescription: parsed.imageDescription || "",
            isBackgroundCommand: true,
          };
        }

        if (parsed.type === "insert-svg") {
          return {
            isSVG: true,
            shapeType: parsed.shapeType,
            properties: parsed.properties || {},
            rawCommand: parsed.rawCommand,
          };
        }

        if (parsed.type === "insert-component") {
          return {
            isComponent: true,
            componentType: parsed.componentType,
            extras: parsed.extras || "",
            rawCommand: parsed.rawCommand,
          };
        }

        if (parsed.type === "insert") {
          return {
            type: parsed.elementType,
            label: parsed.elementType,
            styles: parsed.properties || {},
            content: parsed.content,
            attributes: {
              class: `ml-${parsed.elementType || "element"}`,
            },
            rawCommand: parsed.rawCommand,
          };
        }

        return null;
      }

      async function requestWorkflowCommandFallback(prompt = "") {
        const res = await fetch("/api/workflow/format-command", {
          method: "POST",
          credentials: "include",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ input: prompt }),
        });
        const data = await res.json().catch(() => ({}));
        if (!res.ok || !data.success) return null;

        const rawCommands = Array.isArray(data.commands)
          ? data.commands
          : Array.isArray(data.parsedCommands)
            ? data.parsedCommands.map((entry) => entry.command).filter(Boolean)
            : [];
        const parsedCommands = rawCommands
          .map((command) => parseWorkflowBuilderCommand(command))
          .filter(Boolean);
        const elementSpecs = parsedCommands
          .map((parsed) => workflowCommandToElementSpec(parsed))
          .filter(Boolean);

        if (!elementSpecs.length) return null;
        return {
          parsedCommands,
          elementSpecs,
          formattedCommand: rawCommands.join("\n"),
          source: "workflow-format-fallback",
        };
      }

      /**
       * Parse and apply INSERT_ELEMENT_SPEC action from AI agent.
       * Supports full HTML/CSS/attributes for flexible element creation.
       * Format: INSERT_ELEMENT_SPEC {...JSON...}
       * Allows: html, css, style, class, width, height, x, y, attributes, animations, setup, script, etc.
       *
       * Special properties:
       * - setup: Function to run after element is inserted (receives wrapper element)
       * - script: Inline JavaScript code as string to execute on wrapper (receives wrapper as parameter)
       */
      function applyInsertElementSpec(specJson = {}) {
        try {
          ensureBuilderSections({ skipHistory: true });
          const spec =
            typeof specJson === "string" ? JSON.parse(specJson) : specJson;

          const {
            html = "",
            css = "",
            style = {},
            className = "",
            width = "260px",
            height = "120px",
            x = null,
            y = null,
            attributes = {},
            animations = "",
            text = "",
            id = "",
          } = spec;

          // Create wrapper - matches addObject() exactly
          const wrapper = document.createElement("div");
          wrapper.id = id || `ml-inserted-${Date.now()}`;
          wrapper.setAttribute("data-type", "div"); // CRITICAL: Add data-type like addObject
          wrapper.dataset.customHtml = "true"; // CRITICAL: Prevents builder from overwriting inner contents!
          wrapper.className =
            "canvas-element absolute group transition-shadow active:cursor-grabbing";
          if (className) {
            wrapper.className =
              `${wrapper.className} ${String(className)}`.trim();
          }

          // 8-Point Resizer Matrix - Create programmatically for reliability
          const handles = ["tl", "tr", "bl", "br", "mt", "mb", "ml", "mr"];
          const handlesFragment = document.createDocumentFragment();

          handles.forEach((h) => {
            const handle = document.createElement("div");
            handle.className = `resizer ${h}`;
            // Use inline styles for appearance only - let CSS handle positioning
            Object.assign(handle.style, {
              position: "absolute",
              width: "8px",
              height: "8px",
              backgroundColor: "#06b6d4",
              border: "1px solid white",
              borderRadius: "50%",
              opacity: "0",
              zIndex: "50",
              pointerEvents: "auto",
              transition: "all 0.15s ease",
              cursor:
                h === "tl" || h === "br"
                  ? "nwse-resize"
                  : h === "tr" || h === "bl"
                    ? "nesw-resize"
                    : h === "mt" || h === "mb"
                      ? "ns-resize"
                      : "ew-resize",
              // NOTE: Positioning (top/bottom/left/right/transform) handled by CSS class rules
            });

            handlesFragment.appendChild(handle);
          });

          // Create drag controls programmatically
          const dragDiv = document.createElement("div");
          dragDiv.className = "builder-controls absolute -top-8 left-0";
          Object.assign(dragDiv.style, {
            position: "absolute",
            top: "-32px",
            left: "0",
            display: "flex",
            gap: "6px",
            opacity: "0",
            zIndex: "60",
            pointerEvents: "auto",
            transition: "all 0.2s ease",
          });

          // Create drag handle
          const dragHandle = document.createElement("div");
          dragHandle.className = "drag-handle";
          Object.assign(dragHandle.style, {
            width: "28px",
            height: "28px",
            background: "linear-gradient(135deg, #06b6d4 0%, #2563eb 100%)",
            color: "white",
            borderRadius: "8px",
            border: "1px solid rgba(255,255,255,0.2)",
            display: "flex",
            alignItems: "center",
            justifyContent: "center",
            cursor: "grab",
            boxShadow: "0 8px 12px rgba(0,0,0,0.35)",
            pointerEvents: "auto",
            fontSize: "0",
            padding: "0",
          });
          dragHandle.innerHTML =
            '<i class="fas fa-arrows-alt" style="font-size:10px;"></i>';

          // Create inspector button
          const inspectorBtn = document.createElement("button");
          Object.assign(inspectorBtn.style, {
            width: "28px",
            height: "28px",
            background: "#1e293b",
            color: "#06b6d4",
            borderRadius: "8px",
            border: "1px solid rgba(255,255,255,0.1)",
            display: "flex",
            alignItems: "center",
            justifyContent: "center",
            pointerEvents: "auto",
            cursor: "pointer",
            padding: "0",
            fontSize: "0",
          });
          inspectorBtn.innerHTML =
            '<i class="fas fa-sliders-h" style="font-size:10px;"></i>';
          inspectorBtn.addEventListener("click", (e) => {
            e.stopPropagation();
            openSmartInspector("div", wrapper);
          });
          inspectorBtn.addEventListener("mouseover", () => {
            inspectorBtn.style.background = "#0f172a";
          });
          inspectorBtn.addEventListener("mouseout", () => {
            inspectorBtn.style.background = "#1e293b";
          });

          // Create visibility button
          const visibilityBtn = document.createElement("button");
          visibilityBtn.className = "builder-visibility-btn";
          Object.assign(visibilityBtn.style, {
            width: "28px",
            height: "28px",
            background: "#1e293b",
            color: "#94a3b8",
            borderRadius: "8px",
            border: "1px solid rgba(255,255,255,0.1)",
            display: "flex",
            alignItems: "center",
            justifyContent: "center",
            pointerEvents: "auto",
            cursor: "pointer",
            padding: "0",
            fontSize: "0",
          });
          visibilityBtn.innerHTML =
            '<i class="fas fa-eye" style="font-size:10px;"></i>';
          visibilityBtn.addEventListener("click", (e) => {
            e.stopPropagation();
            if (typeof toggleCanvasElementVisibility === "function") {
              toggleCanvasElementVisibility(wrapper);
            }
          });
          visibilityBtn.addEventListener("mouseover", () => {
            visibilityBtn.style.background = "#0f172a";
          });
          visibilityBtn.addEventListener("mouseout", () => {
            visibilityBtn.style.background = "#1e293b";
          });

          // Create delete button
          const deleteBtn = document.createElement("button");
          Object.assign(deleteBtn.style, {
            width: "28px",
            height: "28px",
            background: "#1e293b",
            color: "#ef4444",
            borderRadius: "8px",
            border: "1px solid rgba(255,255,255,0.1)",
            display: "flex",
            alignItems: "center",
            justifyContent: "center",
            pointerEvents: "auto",
            cursor: "pointer",
            padding: "0",
            fontSize: "0",
          });
          deleteBtn.innerHTML =
            '<i class="fas fa-trash-alt" style="font-size:10px;"></i>';
          deleteBtn.addEventListener("click", (e) => {
            e.stopPropagation();
            wrapper.remove();
            saveToHistory();
          });
          deleteBtn.addEventListener("mouseover", () => {
            deleteBtn.style.background = "#7f1d1d";
          });
          deleteBtn.addEventListener("mouseout", () => {
            deleteBtn.style.background = "#1e293b";
          });

          // Attach drag handle listener BEFORE adding to DOM
          dragHandle.addEventListener("pointerdown", (e) => {
            handleObjectInteraction(e, wrapper);
          });

          dragDiv.appendChild(dragHandle);
          dragDiv.appendChild(visibilityBtn);
          dragDiv.appendChild(inspectorBtn);
          dragDiv.appendChild(deleteBtn);

          // Create badge
          const badgeHtml = renderInteractionBadgeHtml();
          const badgeDiv = document.createElement("div");
          badgeDiv.innerHTML = badgeHtml;

          // Assemble wrapper with all children (no element-body wrapper - content goes directly in wrapper)
          wrapper.appendChild(handlesFragment);
          wrapper.appendChild(dragDiv);
          wrapper.appendChild(badgeDiv.firstChild || badgeDiv);

          // Add hover listeners to show/hide handles and controls
          wrapper.addEventListener("mouseenter", function () {
            const handles = this.querySelectorAll(".resizer");
            handles.forEach((h) => {
              if (h.style.opacity === "0") {
                h.style.opacity = "1";
              }
            });
            const dragControls = this.querySelector("div[style*='gap: 6px']");
            if (dragControls && dragControls.style.opacity === "0") {
              dragControls.style.opacity = "1";
            }
          });

          wrapper.addEventListener("mouseleave", function () {
            // Only hide if not selected
            if (
              !this.classList.contains("selected-premium") &&
              !this.classList.contains("selected-secondary")
            ) {
              const handles = this.querySelectorAll(".resizer");
              handles.forEach((h) => {
                h.style.opacity = "0";
              });
              const dragControls = this.querySelector("div[style*='gap: 6px']");
              if (dragControls) {
                dragControls.style.opacity = "0";
              }
            }
          });

          // Attach resize/drag handler to all handles
          const allHandles = wrapper.querySelectorAll(".resizer");
          allHandles.forEach((handle) => {
            handle.addEventListener("pointerdown", (e) => {
              handleObjectInteraction(e, wrapper);
            });
          });

          // Set wrapper HTML with EXACT same structure as addObject()
          // wrapper.innerHTML = `
          //     ${handlesHTML}
          //     <div class="absolute -top-8 left-0 flex gap-1.5 opacity-0 group-hover:opacity-100 transition-all z-[60]">
          //         <div class="drag-handle w-7 h-7 bg-gradient-to-br from-cyan-500 to-blue-600 text-white rounded-lg border border-white/20 shadow-2xl flex items-center justify-center cursor-grab active:cursor-grabbing pointer-events-auto hover:shadow-cyan-500/50 transition-all select-none"><i class="fas fa-arrows-alt text-[10px]"></i></div>
          //         <button onclick="openSmartInspector('div', this.closest('.canvas-element'))" class="w-7 h-7 bg-gray-950 text-cyan-400 rounded-lg border border-white/10 flex items-center justify-center pointer-events-auto hover:bg-cyan-950 transition-all"><i class="fas fa-sliders-h text-[10px]"></i></button>
          //         <button onclick="this.closest('.canvas-element').remove(); saveToHistory();" class="w-7 h-7 bg-gray-950 text-red-500 rounded-lg border border-white/10 flex items-center justify-center pointer-events-auto hover:bg-red-950 transition-all"><i class="fas fa-trash-alt text-[10px]"></i></button>
          //     </div>
          //     ${renderInteractionBadgeHtml()}
          //     <div class="element-body w-full h-full overflow-visible"></div>
          // `;

          const hasOwn = (obj, key) =>
            Object.prototype.hasOwnProperty.call(obj || {}, key);
          const normalizeCssValue = (value, fallback) => {
            if (value === null || value === undefined) return fallback;
            if (typeof value === "number" && Number.isFinite(value))
              return `${value}px`;
            const text = String(value).trim();
            if (!text) return fallback;
            // Bare numbers should be px.
            if (/^-?\d+(?:\.\d+)?$/.test(text)) return `${text}px`;
            return text;
          };
          const normalizeStyleObject = (inputStyle) => {
            if (!inputStyle || typeof inputStyle !== "object") return {};
            const out = {};
            Object.entries(inputStyle).forEach(([rawKey, rawValue]) => {
              const key = String(rawKey || "").trim();
              if (!key) return;
              const camelKey = key.includes("-")
                ? key.replace(/-([a-z])/g, (_, c) => String(c).toUpperCase())
                : key;
              out[camelKey] = rawValue;
            });
            return out;
          };
          const normalizedStyle = normalizeStyleObject(style);

          // Split style keys: wrapper positioning/size vs body visuals.
          const wrapperStyleKeys = new Set([
            "position",
            "left",
            "top",
            "right",
            "bottom",
            "margin",
            "marginTop",
            "marginLeft",
            "marginRight",
            "marginBottom",
            "width",
            "height",
            "zIndex",
            "opacity",
            "visibility",
            "overflow",
            "pointerEvents",
            "transform",
            "transformOrigin",
          ]);
          const wrapperStyle = {};
          const bodyStyle = {};
          Object.entries(normalizedStyle).forEach(([key, value]) => {
            if (wrapperStyleKeys.has(key)) wrapperStyle[key] = value;
            else bodyStyle[key] = value;
          });

          // Smart positioning: Calculate center of current view
          const canvasEl = document.getElementById("web-canvas");
          let defaultLeft = "100px";
          let defaultTop = "100px";
          
          if (canvasEl && typeof getBuilderCanvasMetrics === "function") {
             const metrics = getBuilderCanvasMetrics(canvasEl);
             const viewW = metrics.scroller?.clientWidth || 300;
             const viewH = metrics.scroller?.clientHeight || 500;
             // Calculate absolute center of the current scroll viewport
             const centerX = metrics.scrollLeft + (viewW / 2);
             const centerY = metrics.scrollTop + (viewH / 2);
             defaultLeft = `${centerX}px`;
             defaultTop = `${centerY}px`;
          }

          let rawLeft = hasOwn(spec, "x") ? x : wrapperStyle.left;
          let rawTop = hasOwn(spec, "y") ? y : wrapperStyle.top;

          // Compute wrapper positioning
          let posLeft = normalizeCssValue(rawLeft, defaultLeft);
          let posTop = normalizeCssValue(rawTop, defaultTop);

          // Smart intercept: aggressively replace ANY percentage (like 50%) or "auto" with the true pixel center
          if (posLeft.includes("%") || posLeft === "auto" || posLeft === "0px" || !rawLeft) {
             posLeft = defaultLeft;
          }
          if (posTop.includes("%") || posTop === "auto" || posTop === "0px" || !rawTop) {
             posTop = defaultTop;
          }

          // Compute wrapper dimensions (prefer explicit width/height or style.width/height).
          const resolvedWidth = normalizeCssValue(
            hasOwn(spec, "width") ? width : wrapperStyle.width,
            "260px",
          );
          const resolvedHeight = normalizeCssValue(
            hasOwn(spec, "height") ? height : wrapperStyle.height,
            "100px",
          );

          // Set wrapper styles like addObject (ensure wrapper owns position/size).
          Object.assign(wrapper.style, {
            position: wrapperStyle.position || "absolute",
            width: resolvedWidth,
            height: resolvedHeight,
            left: posLeft,
            top: posTop,
            zIndex: wrapperStyle.zIndex ?? "1",
            opacity: wrapperStyle.opacity ?? "1",
            visibility: wrapperStyle.visibility ?? "visible",
            overflow: wrapperStyle.overflow ?? "visible",
            pointerEvents: wrapperStyle.pointerEvents ?? "auto",
            margin: wrapperStyle.margin || "",
            marginTop: wrapperStyle.marginTop || "",
            marginLeft: wrapperStyle.marginLeft || "",
            marginBottom: wrapperStyle.marginBottom || "",
            marginRight: wrapperStyle.marginRight || "",
          });
          if (wrapperStyle.transform)
            wrapper.style.transform = wrapperStyle.transform;
          if (wrapperStyle.transformOrigin)
            wrapper.style.transformOrigin = wrapperStyle.transformOrigin;

          // Create a temporary container to parse HTML
          const tempContainer = document.createElement("div");
          let contentElement = null;

          if (html) {
            let cleanHtml = String(html).trim();

            // Remove carousel/navigation buttons and arrow icons only
            // Remove builder layout scroll buttons
            cleanHtml = cleanHtml.replace(
              /<button[^>]*builder-layout-scroll-btn[^>]*>[\s\S]*?<\/button>/gi,
              "",
            );
            // Remove buttons with prev/next classes
            cleanHtml = cleanHtml.replace(
              /<button[^>]*(?:prev|next)[^>]*>[\s\S]*?<\/button>/gi,
              "",
            );
            // Remove div with carousel-related classes
            cleanHtml = cleanHtml.replace(
              /<div[^>]*class="[^"]*(?:carousel-nav|nav-button)[^"]*"[^>]*>[\s\S]*?<\/div>/gi,
              "",
            );
            // Remove all navigation/directional arrow icons EXCEPT fa-arrows-alt (drag handle)
            cleanHtml = cleanHtml.replace(
              /<i[^>]*fa-(?!arrows-alt)(?:chevron|angle|arrow)[^>]*><\/i>/gi,
              "",
            );
            // Remove button elements that contain arrow-like content or navigation
            cleanHtml = cleanHtml.replace(
              /<button[^>]*>[\s\S]*?(?:<i[^>]*fa-(?:chevron|angle|arrow-left|arrow-right)[^>]*>[\s\S]*?<\/i>)[\s\S]*?<\/button>/gi,
              "",
            );
            // Remove standalone < > characters that look like navigation arrows
            cleanHtml = cleanHtml.replace(/(?:<|&lt;)\s*(?:>|&gt;)/g, "");

            const bodyWrapper = document.createElement("div");
            bodyWrapper.className = "element-body w-full h-full overflow-visible";
            bodyWrapper.innerHTML = cleanHtml;

            // Force AI root elements to dock securely to the wrapper to prevent mismatches
            Array.from(bodyWrapper.children).forEach(child => {
              if (child.tagName === "STYLE" || child.tagName === "SCRIPT") return;
              if (child instanceof HTMLElement) {
                child.style.position = "relative";
                child.style.left = "0px";
                child.style.top = "0px";
                child.style.right = "auto";
                child.style.bottom = "auto";
                child.style.margin = "0px";
                child.style.transform = "none";
                child.style.width = "100%";
                child.style.height = "100%";
              }
            });

            contentElement = bodyWrapper;

            // Execute scripts to enable interactive AI elements
            const scripts = contentElement.querySelectorAll("script");
            scripts.forEach((oldScript) => {
              const newScript = document.createElement("script");
              Array.from(oldScript.attributes).forEach((attr) => newScript.setAttribute(attr.name, attr.value));
              newScript.appendChild(document.createTextNode(oldScript.innerHTML));
              oldScript.parentNode.replaceChild(newScript, oldScript);
            });
          } else if (text) {
            const textDiv = document.createElement("div");
            textDiv.textContent = String(text);
            contentElement = textDiv;
          } else {
            const placeholderDiv = document.createElement("div");
            placeholderDiv.innerHTML = `<div style="width:100%; height:100%; display:flex; align-items:center; justify-content:center; color:#999; font-size:14px;">Content</div>`;
            contentElement = placeholderDiv.firstElementChild || placeholderDiv;
          }

          // Style the content element to fill the wrapper
          if (contentElement) {
            contentElement.style.width = contentElement.style.width || "100%";
            contentElement.style.height = contentElement.style.height || "100%";
            contentElement.style.boxSizing = "border-box";
            // Lock inner element position so wrapper bounds perfectly match
            contentElement.style.margin = "0px";
            contentElement.style.marginTop = "0px";
            contentElement.style.marginLeft = "0px";
            contentElement.style.marginRight = "0px";
            contentElement.style.marginBottom = "0px";
            if (contentElement.style.position === "absolute" || contentElement.style.position === "fixed") {
              contentElement.style.position = "relative";
            }
            contentElement.style.top = "0px";
            contentElement.style.left = "0px";
            contentElement.style.right = "auto";
            contentElement.style.bottom = "auto";
          }

          // Apply data attributes
          if (typeof attributes === "object" && attributes !== null) {
            Object.entries(attributes).forEach(([key, value]) => {
              const attrKey = String(key || "").trim();
              if (!attrKey) return;
              if (attrKey === "style" || attrKey === "id") return;
              if (attrKey === "class" || attrKey === "className") {
                wrapper.className =
                  `${wrapper.className} ${String(value || "")}`.trim();
                return;
              }
              wrapper.setAttribute(attrKey, String(value));
            });
          }

          // Inject custom CSS if provided
          if (css) {
            const styleEl = document.createElement("style");
            styleEl.textContent = String(css);
            document.head.appendChild(styleEl);
          }

          // Add animations if provided
          if (animations) {
            const animStyle = document.createElement("style");
            animStyle.textContent = String(animations);
            document.head.appendChild(animStyle);
          }

          // Append content element directly to wrapper (no extra container)
          if (contentElement) {
            wrapper.appendChild(contentElement);
          }

          // Add to canvas and activate
          const canvas = document.getElementById("web-canvas");
          if (canvas) {
            appendCanvasElementToActiveSection(wrapper, {
              skipEnsureSections: true,
            });

            // Call setup function if provided
            if (typeof spec.setup === "function") {
              try {
                spec.setup(wrapper);
              } catch (setupErr) {
                console.error("Setup function error:", setupErr);
              }
            }

            // Execute inline script if provided
            if (spec.script) {
              try {
                const scriptFn = new Function("wrapper", String(spec.script));
                scriptFn(wrapper);
              } catch (scriptErr) {
                console.error("Script execution error:", scriptErr);
              }
            }

            hydrateCanvasElement(wrapper);
            saveToHistory();
            selectElement(wrapper);
          }

          return {
            success: true,
            elementId: wrapper.id,
            message: `Inserted interactive element with ID: ${wrapper.id}`,
          };
        } catch (err) {
          console.error("Insert element spec failed:", err);
          return {
            success: false,
            message: `Failed to insert element: ${err.message}`,
          };
        }
      }

      // SMART AI INSERT SYSTEM - Flexible, creative element generation
      function analyzeSmartInsertDescription(userInput) {
        const input = String(userInput || "")
          .toLowerCase()
          .trim();

        // Extract shape/type
        const shapeMatch = input.match(
          /\b(ring|circle|box|square|wave|line|dot|ball|card|container|shape)\b/,
        );
        const shape = shapeMatch ? shapeMatch[1] : "box";

        // Extract animations
        const animations = [];
        if (/bouncy|bounce|bouncing/.test(input)) animations.push("bounce");
        if (/spin|spinning|rotate|rotating|rotation/.test(input))
          animations.push("spin");
        if (/pulse|pulsing|pulsate/.test(input)) animations.push("pulse");
        if (/wave|waves|waving/.test(input)) animations.push("wave");
        if (/glow|glowing|glowEffect/.test(input)) animations.push("glow");
        if (/slide|sliding|slide/.test(input)) animations.push("slide");
        if (/fade|fading|fadeIn|fadeOut/.test(input)) animations.push("fade");
        if (/shake|shaking|tremor/.test(input)) animations.push("shake");
        if (/float|floating|hover/.test(input)) animations.push("float");

        // Extract colors - comprehensive color detection
        const colorMap = {
          neon: "neon",
          cyan: "#00FFFF",
          lime: "#00FF00",
          magenta: "#FF00FF",
          pink: "#FF1493",
          red: "#FF0000",
          blue: "#0066FF",
          purple: "#9500FF",
          orange: "#FF6600",
          yellow: "#FFD700",
          green: "#00CC00",
          white: "#FFFFFF",
          black: "#000000",
          gold: "#FFD700",
          silver: "#C0C0C0",
          gradient: "gradient",
          rainbow: "rainbow",
        };

        let color = "#0066FF"; // default blue
        for (const [keyword, colorValue] of Object.entries(colorMap)) {
          if (input.includes(keyword)) {
            color = colorValue;
            break;
          }
        }

        // Extract size
        let size = "medium"; // small, medium, large
        if (/\b(small|tiny|mini|xs)\b/.test(input)) size = "small";
        if (/\b(large|big|xl|huge)\b/.test(input)) size = "large";
        if (/\b(medium|md)\b/.test(input)) size = "medium";

        // Extract border info
        const borderMatch = input.match(
          /border\s+(left|right|top|bottom|all|none)?/,
        );
        const borderPosition = borderMatch ? borderMatch[1] || "all" : null;
        const hasBorder = /border|outline|stroke/.test(input);

        // Extract effects
        const effects = [];
        if (/shadow|glow|blur|effect/.test(input)) effects.push("shadow");
        if (/gradient/.test(input)) effects.push("gradient");
        if (/blur/.test(input)) effects.push("blur");
        if (/frosted|glass|transparent/.test(input)) effects.push("frosted");

        return {
          shape,
          animations,
          color,
          size,
          borderPosition,
          hasBorder,
          effects,
          originalInput: userInput,
        };
      }

      function generateSmartCanvasElementSpec(analysis) {
        const {
          shape,
          animations,
          color,
          size,
          borderPosition,
          hasBorder,
          effects,
        } = analysis;

        // Generate unique animation class for this element
        const animationClass = `smart-anim-${Date.now()}-${Math.random().toString(36).substr(2, 9)}`;

        // Size mappings
        const sizeMap = {
          small: { w: 80, h: 80, border: 2 },
          medium: { w: 150, h: 150, border: 3 },
          large: { w: 250, h: 250, border: 4 },
        };
        const dims = sizeMap[size] || sizeMap.medium;

        // Color value (handle neon gradient)
        let primaryColor = color;
        if (color === "neon") {
          primaryColor = "#00FFFF";
        }

        let html = "";
        let css = "";
        let animations_css = "";
        let label = `${analysis.originalInput}`;

        // Generate HTML based on shape
        if (shape === "ring" || shape === "circle") {
