      function initCanvasSelection(canvas) {
        canvas.onpointerdown = (e) => {
          if (e.target !== canvas) return;
          if (builderCodeMode) return;
          if (isCollaborationViewOnly()) return;
          const rect = canvas.getBoundingClientRect();
          const startX = e.clientX - rect.left + canvas.scrollLeft;
          const startY = e.clientY - rect.top + canvas.scrollTop;
          let moved = false;
          deselectAll();
          if (!selectionBoxEl) return;
          selectionBoxEl.classList.remove("hidden");
          Object.assign(selectionBoxEl.style, {
            left: `${startX}px`,
            top: `${startY}px`,
            width: "0px",
            height: "0px",
          });
          const onMove = (ev) => {
            moved = true;
            const currentX = ev.clientX - rect.left + canvas.scrollLeft;
            const currentY = ev.clientY - rect.top + canvas.scrollTop;
            const left = Math.min(startX, currentX);
            const top = Math.min(startY, currentY);
            const width = Math.abs(currentX - startX);
            const height = Math.abs(currentY - startY);
            Object.assign(selectionBoxEl.style, {
              left: `${left}px`,
              top: `${top}px`,
              width: `${width}px`,
              height: `${height}px`,
            });
          };
          const onUp = () => {
            document.removeEventListener("pointermove", onMove);
            document.removeEventListener("pointerup", onUp);
            selectionBoxEl.classList.add("hidden");
            if (!moved) return;
            const box = {
              left: parseFloat(selectionBoxEl.style.left || "0"),
              top: parseFloat(selectionBoxEl.style.top || "0"),
              right:
                parseFloat(selectionBoxEl.style.left || "0") +
                parseFloat(selectionBoxEl.style.width || "0"),
              bottom:
                parseFloat(selectionBoxEl.style.top || "0") +
                parseFloat(selectionBoxEl.style.height || "0"),
            };
            multiSelectMode = true;
            Array.from(
              canvas.querySelectorAll(":scope > .canvas-element"),
            ).forEach((el) => {
              const elBox = {
                left: el.offsetLeft,
                top: el.offsetTop,
                right: el.offsetLeft + el.offsetWidth,
                bottom: el.offsetTop + el.offsetHeight,
              };
              const intersects =
                elBox.left < box.right &&
                elBox.right > box.left &&
                elBox.top < box.bottom &&
                elBox.bottom > box.top;
              if (intersects) toggleElementSelection(el);
            });
            updateBuilderUI();
          };
          document.addEventListener("pointermove", onMove);
          document.addEventListener("pointerup", onUp);
        };
      }
