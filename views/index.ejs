          .querySelectorAll(
            ".resizer, .drag-handle, .builder-selection-chip, .builder-guide, .builder-layout-guide-overlay, .builder-layout-slot-guide, .builder-selection-box, .builder-layout-scroll-assist, .absolute.-top-8, .absolute.-top-10, .builder-controls, .interaction-badge, [contenteditable='true'], [data-editor]",
          )
          .forEach((node) => {
            if (node.hasAttribute?.("contenteditable")) {
              node.removeAttribute("contenteditable");
