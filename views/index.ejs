              ? "bg-rose-500"
              : "bg-cyan-400",
        );
        const safePercent = Math.max(0, Math.min(100, Number(percent) || 0));
        bar.style.width = `${safePercent}%`;
        percentLabel.innerText = `${Math.round(safePercent)}%`;
