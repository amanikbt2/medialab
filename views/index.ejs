      function extractSemanticSignatures(path = "", content = "") {
        const ext = getBuilderFileExtension(path);
        const lines = String(content || "").split(/\r?\n/);
        if (!["js", "ts", "jsx", "tsx", "mjs", "cjs"].includes(ext)) return [];
        const signatures = [];
        const patterns = [
          /^\s*export\s+function\s+([A-Za-z_$][\w$]*)\s*\(/,
          /^\s*function\s+([A-Za-z_$][\w$]*)\s*\(/,
          /^\s*export\s+const\s+([A-Za-z_$][\w$]*)\s*=\s*\(/,
          /^\s*const\s+([A-Za-z_$][\w$]*)\s*=\s*\(/,
          /^\s*class\s+([A-Za-z_$][\w$]*)\b/,
          /^\s*export\s+class\s+([A-Za-z_$][\w$]*)\b/,
        ];
        lines.forEach((line) => {
          for (const pattern of patterns) {
            const match = line.match(pattern);
            if (match?.[1]) {
              signatures.push(match[1]);
              break;
            }
          }
        });
        return Array.from(new Set(signatures)).slice(0, 48);
      }
