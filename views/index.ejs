        const destination = String(
          document.getElementById("redeem-destination-input")?.value || "",
        ).trim();
        const amount = Number(
          document.getElementById("redeem-amount-input")?.value || 0,
        );
        if (!selectedXPRedemptionMethod) {
          showRedeemProError("Select a redemption method first.");
          return null;
        }
        if (!destination) {
          showRedeemProError("Enter your payout destination.");
          return null;
        }
        if (
          selectedXPRedemptionMethod === "paypal" &&
          !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(destination)
        ) {
          showRedeemProError("Enter a valid PayPal email address.");
          return null;
        }
        if (
          (selectedXPRedemptionMethod === "mpesa" ||
            selectedXPRedemptionMethod === "airtel") &&
          !/^\+?[0-9]{9,15}$/.test(destination.replace(/\s+/g, ""))
        ) {
          showRedeemProError("Enter a valid phone number with country code.");
          return null;
        }
        if (!Number.isFinite(amount) || amount < 5) {
          showRedeemProError("Minimum redemption is 1000 XP.");
          return null;
        }
        if (amount > balance) {
          showRedeemProError(
            "XP Redemption amount cannot exceed your available balance.",
          );
          return null;
        }
        return {
          method: selectedXPRedemptionMethod,
          destination,
          amount: Number(amount.toFixed(2)),
          fee: 0,
        };
