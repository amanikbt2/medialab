          320,
          canvas?.scrollHeight || canvas?.clientHeight || 720,
        );
        const clamp = (value, min, max) =>
          Math.max(min, Math.min(max, Number(value) || 0));
        const maxLeft = Math.max(0, canvasWidth - width);
        const maxTop = Math.max(0, canvasHeight - height);
        const pairMatch = text.match(
          /\b(?:at|to|position(?:ed)?(?: at)?)\s+(-?\d{1,5})\s*,\s*(-?\d{1,5})\b/i,
        );
        const xMatch = text.match(/\b(?:x|left)\s*[:=]?\s*(-?\d{1,5})\b/i);
        const yMatch = text.match(/\b(?:y|top)\s*[:=]?\s*(-?\d{1,5})\b/i);
        if (pairMatch || xMatch || yMatch) {
          const left = pairMatch
            ? Number(pairMatch[1])
            : xMatch
              ? Number(xMatch[1])
              : Math.round((canvasWidth - width) / 2);
          const top = pairMatch
            ? Number(pairMatch[2])
            : yMatch
              ? Number(yMatch[1])
              : Math.round((canvasHeight - height) / 2);
          return {
            left: clamp(left, 0, maxLeft),
            top: clamp(top, 0, maxTop),
