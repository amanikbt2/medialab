      async function connectDataExplorer() {
        if (!dataExplorerEngineConfirmed) {
          showBuilderSnackbar(
            "Select a database type and continue first.",
            "error",
          );
          return;
        }
        if (dataExplorerEngine === "virtual-medialabdb") {
          await connectVirtualMediaLabDb();
          return;
        }
        if (dataExplorerEngine === "sql") {
          showBuilderSnackbar(
            "SQL mode will be added in a later update.",
            "error",
          );
          return;
        }
        const input = document.getElementById("data-explorer-uri-input");
        const uri = String(input?.value || dataExplorerUriDraft || "").trim();
        if (!uri) {
          showBuilderSnackbar("Enter a MongoDB URI first.", "error");
          return;
        }
        dataExplorerUriDraft = uri;
        dataExplorerLoading = true;
        renderDataExplorerTool();
        try {
          const res = await fetch("/api/data-explorer/connect", {
            method: "POST",
            credentials: "include",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({ uri }),
          });
          const data = await res.json().catch(() => ({}));
          if (!res.ok || !data.success) {
            throw new Error(
              data.message || "Could not connect to that MongoDB URI.",
            );
          }
          dataExplorerConnected = true;
          dataExplorerDbName = String(data.dbName || "");
          dataExplorerUriLabel = String(data.uriLabel || "");
          dataExplorerCollections = Array.isArray(data.collections)
            ? data.collections
            : [];
          dataExplorerChannelId = String(
            data.channelId || dataExplorerChannelId || "",
          );
          if (dataExplorerChannelId && socket.connected) {
            socket.emit("data-explorer:subscribe", {
              channelId: dataExplorerChannelId,
            });
          }
          dataExplorerSelectedCollection = dataExplorerCollections[0] || "";
          if (dataExplorerSelectedCollection) {
            await loadDataExplorerCollection(dataExplorerSelectedCollection);
          }
          dataExplorerUriDraft = "";
          showBuilderSnackbar("Database connected.", "success");
        } catch (error) {
          showBuilderSnackbar(
            error.message || "Could not connect to MongoDB.",
            "error",
          );
        } finally {
          dataExplorerLoading = false;
          renderDataExplorerTool();
        }
      }
      async function refreshDataExplorerCollections() {
        try {
          if (dataExplorerEngine === "virtual-medialabdb") {
            await refreshVirtualDbModelIndex();
            renderDataExplorerTool();
            return;
          }
          const res = await fetch("/api/data-explorer/collections", {
            credentials: "include",
          });
          const data = await res.json().catch(() => ({}));
          if (!res.ok || !data.success) {
            throw new Error(data.message || "Could not load collections.");
          }
          dataExplorerConnected = true;
          dataExplorerCollections = Array.isArray(data.collections)
            ? data.collections
            : [];
          dataExplorerDbName = String(data.dbName || dataExplorerDbName || "");
          if (
            !dataExplorerSelectedCollection &&
            dataExplorerCollections.length
          ) {
            dataExplorerSelectedCollection = dataExplorerCollections[0];
          }
          renderDataExplorerTool();
        } catch (error) {
          showBuilderSnackbar(
            error.message || "Could not refresh collections.",
            "error",
          );
        }
      }
      async function loadDataExplorerCollection(collectionName = "") {
        const collection = String(collectionName || "").trim();
        if (!collection) return;
        if (dataExplorerEngine === "virtual-medialabdb") {
          dataExplorerSelectedCollection = collection;
          dataExplorerLoading = true;
          renderDataExplorerTool();
          try {
            const res = await fetch(
              `/api/virtualdb/model/${encodeURIComponent(collection)}`,
              {
                credentials: "include",
              },
            );
            const data = await res.json().catch(() => ({}));
            if (!res.ok || !data.success) {
              throw new Error(data.message || "Could not load that model.");
            }
            dataExplorerDocuments = Array.isArray(data.documents)
              ? data.documents
              : [];
            dataExplorerFields = Array.isArray(data.fields) ? data.fields : [];
          } catch (error) {
            showBuilderSnackbar(
              error.message || "Could not load model.",
              "error",
            );
          } finally {
            dataExplorerLoading = false;
            renderDataExplorerTool();
          }
          return;
        }
        if (
          collection === dataExplorerSelectedCollection &&
          dataExplorerDocuments.length
        ) {
          renderDataExplorerTool();
          return;
        }
        dataExplorerSelectedCollection = collection;
        dataExplorerLoading = true;
        renderDataExplorerTool();
        try {
          const res = await fetch(
            `/api/data-explorer/collection/${encodeURIComponent(collection)}?limit=60`,
            {
              credentials: "include",
            },
          );
