      }
      #web-canvas.magic-fix-active::before {
        content: "";
        position: absolute;
        inset: -25% -35%;
        pointer-events: none;
        z-index: 45;
        background:
          radial-gradient(
            circle at 20% 30%,
            rgba(34, 211, 238, 0.24),
            transparent 36%
          ),
          radial-gradient(
            circle at 78% 62%,
            rgba(251, 191, 36, 0.2),
            transparent 32%
          ),
          linear-gradient(
            112deg,
            rgba(255, 255, 255, 0) 0%,
            rgba(255, 255, 255, 0) 38%,
            rgba(255, 255, 255, 0.5) 50%,
            rgba(255, 255, 255, 0) 62%,
            rgba(255, 255, 255, 0) 100%
          );
        mix-blend-mode: screen;
        opacity: 0;
        animation: mlMagicWipeSweep 0.85s cubic-bezier(0.2, 0.72, 0.18, 1)
          forwards;
      }
      #web-canvas.magic-fix-active::after {
        content: "";
        position: absolute;
        inset: 0;
        pointer-events: none;
        z-index: 44;
        background-image:
          radial-gradient(
            circle,
            rgba(255, 255, 255, 0.65) 0 1px,
            transparent 1.8px
          ),
          radial-gradient(
            circle,
            rgba(34, 211, 238, 0.42) 0 1px,
            transparent 2px
          );
        background-size:
          34px 34px,
          48px 48px;
        background-position:
          0 0,
          12px 18px;
        opacity: 0;
        animation: mlMagicSparkleField 0.8s ease-out forwards;
      }
