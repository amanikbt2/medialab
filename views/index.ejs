      function bindWordProcessorChrome() {
        const workspace = document.getElementById("word-processor-workspace");
        if (!workspace || workspace.dataset.chromeBound === "true") return;
        const revealRibbon = () => showWordRibbon();
        const hideRibbonOnOutsideClick = (event) => {
          if (workspace.classList.contains("hidden")) return;
          const toolbar = workspace.querySelector(
            ".word-processor-toolbar-shell",
          );
          if (toolbar && !toolbar.contains(event.target)) {
            workspace.classList.add("ribbon-hidden");
