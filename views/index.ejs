          doc.querySelectorAll('link[rel="stylesheet"][href]'),
        ).forEach((node) => {
          const href = String(node.getAttribute("href") || "").trim();
          const resolved = resolveBuilderProjectPath(htmlPath, href);
          if (
            !resolved ||
            (resolved === href && !findBuilderNodeByPath(resolved))
          )
            return;
          const cssNode = findBuilderNodeByPath(resolved);
          if (!cssNode || cssNode.type !== "file") return;
          const style = doc.createElement("style");
          style.setAttribute("data-builder-linked-href", href);
          style.textContent = String(cssNode.content || "");
          node.replaceWith(style);
        });
        Array.from(doc.querySelectorAll("script[src]")).forEach((node) => {
          const src = String(node.getAttribute("src") || "").trim();
          const resolved = resolveBuilderProjectPath(htmlPath, src);
          if (
            !resolved ||
            (resolved === src && !findBuilderNodeByPath(resolved))
          )
            return;
          const jsNode = findBuilderNodeByPath(resolved);
          if (!jsNode || jsNode.type !== "file") return;
          const script = doc.createElement("script");
          script.setAttribute("data-builder-linked-src", src);
          script.textContent = String(jsNode.content || "");
          node.replaceWith(script);
        });
        const runtimeDocument =
          "<!DOCTYPE html>\n" + doc.documentElement.outerHTML;
        return injectBuilderDataBindingRuntime(runtimeDocument);
      }
      function buildBuilderDataBindingRuntimeScript() {
        return [
          "<script>",
          "(() => {",
          '  const resolveValue = (obj, path) => String(path || "").split(".").filter(Boolean).reduce((acc, key) => acc == null ? acc : acc[key], obj);',
          "  const applyValue = (el, value) => {",
          '    const text = value == null ? "" : typeof value === "object" ? JSON.stringify(value) : String(value);',
          '    const body = el.querySelector(".element-body > *") || el.querySelector(".element-body") || el;',
          "    if (!body) return;",
          '    if (body.tagName === "IMG") {',
          "      body.src = text;",
          "      return;",
          "    }",
          '    if (body.tagName === "INPUT" || body.tagName === "TEXTAREA") {',
          "      body.value = text;",
          "      return;",
          "    }",
          "    body.textContent = text;",
          "  };",
          "  const hydrate = async () => {",
          '    const nodes = Array.from(document.querySelectorAll("[data-bind-collection][data-bind-field]"));',
          "    if (!nodes.length) return;",
          "    const groups = new Map();",
          "    nodes.forEach((node) => {",
          '      const collection = node.getAttribute("data-bind-collection") || "";',
          "      if (!groups.has(collection)) groups.set(collection, []);",
          "      groups.get(collection).push(node);",
          "    });",
          "    for (const [collection, items] of groups.entries()) {",
          "      try {",
          "        const res = await fetch('/api/data-explorer/collection/' + encodeURIComponent(collection) + '?limit=60', { credentials: 'include' });",
          "        const data = await res.json().catch(() => ({}));",
          "        if (!res.ok || !data.success) continue;",
          "        items.forEach((node) => {",
          '          const fieldPath = node.getAttribute("data-bind-field") || "";',
          '          const index = Math.max(0, Number(node.getAttribute("data-bind-index") || 0) || 0);',
          "          const doc = Array.isArray(data.documents) ? data.documents[index] : null;",
          "          applyValue(node, resolveValue(doc || {}, fieldPath));",
          "        });",
          "      } catch {}",
          "    }",
          "  };",
          "  hydrate();",
          "})();",
          "</scr" + "ipt>",
        ].join("\n");
      }
      function injectBuilderDataBindingRuntime(documentHtml = "") {
        const html = String(documentHtml || "");
        if (!/data-bind-collection=/i.test(html)) return html;
        const runtimeScript = buildBuilderDataBindingRuntimeScript();
        if (html.includes("</body>")) {
          return html.replace("</body>", `${runtimeScript}\n</body>`);
        }
        return `${html}\n${runtimeScript}`;
      }
      function buildBuilderPublishPackage() {
        persistActiveBuilderFileContent();
        const vfsEntries = stripRootBuilderFolder(
          collectBuilderProjectFileEntries().filter((item) => item.path),
        );
        const importedFiles = Array.isArray(builderImportedProject?.files)
          ? builderImportedProject.files
          : [];
        const importedMap = new Map(
          importedFiles.map((file) => [
            normalizeImportedProjectPath(file?.path || ""),
            file,
          ]),
        );
        const normalizedTextEntries = vfsEntries.map((entry) => ({
          path: normalizeImportedProjectPath(entry.path || ""),
          content: isBuilderHtmlFile(entry.path || "")
            ? buildBuilderRuntimeDocument(
                entry.path,
                String(entry.content || ""),
                {
                  inlineLocalAssets: false,
                },
              )
            : String(entry.content || ""),
        }));
        const mergedFiles = [];
        const seenPaths = new Set();
        normalizedTextEntries.forEach((entry) => {
          const imported = importedMap.get(entry.path);
          mergedFiles.push({
            path: entry.path,
            contentBase64: encodeBuilderTextBase64(entry.content),
            mimeType: imported?.mimeType || guessBuilderMimeType(entry.path),
          });
          seenPaths.add(entry.path);
        });
        importedFiles.forEach((file) => {
          const path = normalizeImportedProjectPath(file?.path || "");
          if (!path || seenPaths.has(path)) return;
          mergedFiles.push({
            path,
            contentBase64: String(file?.contentBase64 || "").trim(),
            mimeType: file?.mimeType || guessBuilderMimeType(path),
          });
        });
        const entryPath =
          stripRootBuilderFolder([
            { path: getFirstBuilderHtmlFilePath() || "index.html" },
          ])[0]?.path || "index.html";
        return {
          entryPath: normalizeImportedProjectPath(entryPath),
          files: mergedFiles.filter((file) => file.path && file.contentBase64),
        };
      }
      function resetBuilderProjectFiles({ preserveName = false } = {}) {
        builderProjectFiles = createDefaultBuilderProjectFiles();
