      function beginUniversalProgress(
        message = "Working...",
        start = 10,
        cap = 94,
      ) {
        clearUniversalProgressPulse();
        let current = Math.max(0, Math.min(cap, start));
        setUniversalProgress({
          visible: true,
          message,
          percent: current,
          tone: "cyan",
        });
        universalProgressPulse = setInterval(() => {
          current = Math.min(
            cap,
            current + (current < 40 ? 5 : current < 70 ? 3 : 1),
          );
          setUniversalProgress({
            visible: true,
            message,
            percent: current,
            tone: "cyan",
          });
        }, 520);
      }
