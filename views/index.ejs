      function smartCleanDocument() {
        const editor = document.getElementById("text-input");
        if (!editor) return;
        const blocks = Array.from(
          editor.querySelectorAll("p, div, li, h1, h2, h3, blockquote, pre"),
        );
        blocks.forEach((block) => {
          if (!block.querySelector("img, table, hr")) {
            block.innerHTML = block.innerHTML
              .replace(/&nbsp;/g, " ")
              .replace(/[ \t]{2,}/g, " ")
              .replace(/\s+<br>/g, "<br>")
              .trim();
          }
        });
        Array.from(editor.querySelectorAll("p, div"))
          .filter(
            (node) =>
              !node.querySelector("img, table, hr") &&
              !node.textContent.replace(/\u00a0/g, " ").trim(),
          )
          .forEach((node) => node.remove());
        editor.innerHTML = editor.innerHTML
          .replace(/(&nbsp;|\s){2,}/g, " ")
          .replace(/(<br\s*\/?>\s*){3,}/gi, "<br><br>")
          .replace(
            /(<p>(?:\s|&nbsp;|<br\s*\/?>)*<\/p>\s*){2,}/gi,
            "<p><br></p>",
