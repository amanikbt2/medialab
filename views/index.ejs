        if (!canvas) return "";

        const clone = canvas.cloneNode(true);
        clone.removeAttribute("id");
        clone.style.margin = "0 auto";
        clone.style.maxWidth = "none";
        clone.style.borderRadius = "0";
        clone.style.boxShadow = "none";
        clone.style.overflow = "visible";

        // Remove editor-specific elements
        clone
          .querySelectorAll(
            ".resizer, .drag-handle, .builder-selection-chip, .builder-guide, .builder-layout-guide-overlay, .builder-layout-slot-guide, .builder-selection-box, .builder-layout-scroll-assist, [contenteditable='true']",
          )
          .forEach((node) => {
            if (node.hasAttribute?.("contenteditable")) {
              node.removeAttribute("contenteditable");
              return;
            }
            node.remove();
          });

        // Use canvas decompiler if available for better accuracy
        let canvasHtml = clone.innerHTML;
        if (
          typeof BuilderAIAgents !== "undefined" &&
          BuilderAIAgents.CanvasDecompiler
        ) {
          try {
            const tempContainer = document.createElement("div");
            tempContainer.innerHTML = canvasHtml;
            const decompiled = await BuilderAIAgents.CanvasDecompiler.decompile(
              `<!DOCTYPE html><html><body>${canvasHtml}</body></html>`,
              { stripEditorData: true, normalizeSpacing: true },
            );
            const decompileDoc = new DOMParser().parseFromString(
              decompiled,
              "text/html",
            );
            canvasHtml = decompileDoc.body?.innerHTML || canvasHtml;
          } catch (error) {
            console.warn(
              "Canvas decompilation failed, using basic approach",
              error,
            );
          }
        }

        const pageBackground = getCanvasPageStyleState(canvas).background;
        const dynamicCss = syncStyleTag({ forExport: true });
        const width = Math.max(
          canvas.scrollWidth,
          canvas.offsetWidth,
          parseFloat(canvas.style.width || "0") || 0,
        );
        const height = Math.max(
          canvas.scrollHeight,
          canvas.offsetHeight,
          parseFloat(canvas.style.height || "0") || 0,
        );

        const interactionEntries = [];
        canvas
          .querySelectorAll(":scope > .canvas-element")
          .forEach((sourceNode) => {
            const clonedNodeId = sourceNode.id;
            if (!clonedNodeId) return;
            Object.entries(
              normalizeElementInteractions(
                JSON.parse(sourceNode.dataset.interactions || "{}"),
              ),
            ).forEach(([eventName, action]) => {
              interactionEntries.push({
                sourceId: clonedNodeId,
                eventName,
                action,
              });
            });
          });

        const interactionScript = buildInteractionScriptForExport(
          interactionEntries,
          {
            defaultSectionId: getDefaultSectionIdForRuntime(clone),
          },
        );
        const interactionBlock = interactionScript
          ? `\n${interactionScript}`
          : "";

        return `<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>MediaLab Run Preview</title>
    <style>
      html, body {
        margin: 0;
        min-height: 100%;
        background: ${pageBackground};
        overflow: auto;
      }
      body {
        position: relative;
        font-family: Inter, system-ui, sans-serif;
      }
${String(builderImportedGlobalCss || "").trim()}
      .canvas-element,
      .absolute {
        position: absolute;
      }
      .canvas-element.in-layout-flow {
        position: static !important;
      }
      .element-body {
        width: 100%;
        height: 100%;
        box-sizing: border-box;
      }
${dynamicCss}
      #medialab-run-stage {
        position: relative;
        width: ${Math.max(320, Math.round(width))}px;
        min-width: ${Math.max(320, Math.round(width))}px;
        height: ${Math.max(320, Math.round(height))}px;
        min-height: ${Math.max(320, Math.round(height))}px;
        background: ${pageBackground};
        overflow: visible;
      }
    </style>
  </head>
  <body>
    <div id="medialab-run-stage">${canvasHtml}</div>
${interactionBlock}
  </body>
</html>`;
      }
