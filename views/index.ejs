      async function loadBuilderSiteTemplate(slug) {
        const selectedTemplate = (
          Array.isArray(builderCommunityTemplates)
            ? builderCommunityTemplates
            : []
        ).find(
          (item) =>
            String(item?.slug || "").trim() === String(slug || "").trim(),
        );
        const labels = {
          candycrush: "Candy Crush Game",
          portfolio: "Portfolio Site",
          arcade: "Game Launch",
          studio: "Creative Studio",
        };
        const editor = document.getElementById("builder-code-editor");
        if (!editor) return;
        const centerCanvasElementsInViewport = () => {
          const canvas = document.getElementById("web-canvas");
          const container = document.getElementById("canvas-container");
          if (!canvas || !container) return;
          const nodes = Array.from(
            canvas.querySelectorAll(":scope > .canvas-element"),
          );
          if (!nodes.length) return;
          let minLeft = Number.POSITIVE_INFINITY;
          let minTop = Number.POSITIVE_INFINITY;
          let maxRight = Number.NEGATIVE_INFINITY;
          let maxBottom = Number.NEGATIVE_INFINITY;
          nodes.forEach((node) => {
            const left =
              Number.parseFloat(node.style.left || "") || node.offsetLeft || 0;
            const top =
              Number.parseFloat(node.style.top || "") || node.offsetTop || 0;
            const width = Math.max(1, node.offsetWidth || 1);
            const height = Math.max(1, node.offsetHeight || 1);
            minLeft = Math.min(minLeft, left);
            minTop = Math.min(minTop, top);
            maxRight = Math.max(maxRight, left + width);
            maxBottom = Math.max(maxBottom, top + height);
          });
          if (!Number.isFinite(minLeft) || !Number.isFinite(minTop)) return;
          const contentWidth = Math.max(1, maxRight - minLeft);
          const contentHeight = Math.max(1, maxBottom - minTop);
          const viewportCenterX =
            container.scrollLeft + container.clientWidth / 2;
          const viewportCenterY =
            container.scrollTop + container.clientHeight / 2;
          const desiredLeft = viewportCenterX - contentWidth / 2;
          const desiredTop = viewportCenterY - contentHeight / 2;
          const dx = desiredLeft - minLeft;
          const dy = desiredTop - minTop;
          nodes.forEach((node) => {
            const left =
              Number.parseFloat(node.style.left || "") || node.offsetLeft || 0;
            const top =
              Number.parseFloat(node.style.top || "") || node.offsetTop || 0;
            node.style.left = `${left + dx}px`;
            node.style.top = `${top + dy}px`;
          });
        };
        try {
          const timeoutMs = 15000;
          const timeoutController = new AbortController();
          let timeoutId = null;
          const startTimeout = () =>
            new Promise((_, reject) => {
              timeoutId = setTimeout(() => {
                timeoutController.abort();
                reject(new Error("FAILED_TEMPLATE_INSERT_TIMEOUT"));
              }, timeoutMs);
            });
          beginUniversalProgress(
            `Loading ${selectedTemplate?.title || labels[slug] || "website"} template...`,
            14,
            88,
          );
          const loadOperation = async () => {
            let html = String(selectedTemplate?.sourceHtml || "");
            if (!html) {
              const res = await fetch(`/templates/${slug}`, {
                credentials: "same-origin",
                signal: timeoutController.signal,
              });
              if (!res.ok) {
                throw new Error(`Template request failed: ${res.status}`);
              }
              html = await res.text();
            }
            const ownerName =
              String(currentUser?.name || "Your Game World").trim() ||
              "Your Game World";
            html = html.replace(/__MEDIALAB_OWNER_NAME__/g, ownerName);
            builderImportedProject = null;
            builderRawImportDocument = html;
            builderLoadedTemplateSlug = String(slug || "")
              .trim()
              .toLowerCase();
            builderTemplateRuntimeDocument = html;
            setBuilderProjectFromEntries(
              selectedTemplate?.title || labels[slug] || "Website Template",
              [{ path: "index.html", content: html }],
              "index.html",
            );
            builderCodeMode = true;
            updateBuilderUI();
            editor.value = html;
            handleBuilderCodeInput();
            tryApplyCodeModeToCanvas(true);
            centerCanvasElementsInViewport();
            builderCodeMode = false;
            updateBuilderUI();
            preserveBuilderFullscreenAfterUpload();
            completeUniversalProgress(
              `${selectedTemplate?.title || labels[slug] || "Website"} ready.`,
            );
            showBuilderSnackbar(
              `${selectedTemplate?.title || labels[slug] || "Website"} loaded into the canvas.`,
              "success",
            );
          };
          await Promise.race([loadOperation(), startTimeout()]);
          if (timeoutId) clearTimeout(timeoutId);
        } catch (error) {
          const isInsertTimeout =
            error?.message === "FAILED_TEMPLATE_INSERT_TIMEOUT" ||
            error?.name === "AbortError";
          console.error("Template load failed:", error);
          failUniversalProgress("Template loading failed.");
          showBuilderSnackbar(
            isInsertTimeout
              ? "failed to insert template, please try again"
              : "Could not load that website template right now.",
            "error",
          );
        }
      }
