                dataBinding: existingEl.dataset.bindCollection
                  ? {
                      collection: String(
                        existingEl.dataset.bindCollection || "",
                      ),
                      fieldPath: String(existingEl.dataset.bindField || ""),
                      documentIndex:
                        Number(existingEl.dataset.bindIndex || 0) || 0,
                    }
