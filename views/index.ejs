          if (!track?.kind) return;
          const currentTrack = mergedStream
            .getTracks()
            .find((item) => item.kind === track.kind);
          if (currentTrack && currentTrack.id === track.id) return;
          if (currentTrack) {
            try {
              mergedStream.removeTrack(currentTrack);
            } catch {}
          }
          try {
            mergedStream.addTrack(track);
          } catch {}
          track.onended = () => {
            try {
              mergedStream.removeTrack(track);
            } catch {}
            const latestEntry = collaborationRemoteStreams.get(key);
            if (latestEntry?.stream === mergedStream) {
              renderCollaborationVideoStage();
            }
