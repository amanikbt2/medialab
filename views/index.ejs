        // Preserve exact inline styles and exported layout styles of all canvas elements.
        const preserveElementStyles = (cloned, original) => {
          if (
            !(cloned instanceof HTMLElement) ||
            !(original instanceof HTMLElement)
          )
            return;

          const wrapperStyle = String(
            original.style.cssText || original.dataset.mlWrapperStyle || "",
          ).trim();
          if (wrapperStyle) {
            cloned.style.cssText = wrapperStyle;
          } else {
            const positioningStyle = extractPositioningStyles(
              String(
                original.dataset.mlWrapperStyle || original.style.cssText || "",
              ),
            );
            if (positioningStyle) cloned.style.cssText = positioningStyle;
          }

          const originalInner = getElementInnerNode(original);
          const clonedInner = getElementInnerNode(cloned);
          const innerStyle = String(
            originalInner?.style?.cssText ||
              original.dataset.mlInnerStyle ||
              "",
          ).trim();
          if (clonedInner && innerStyle) clonedInner.style.cssText = innerStyle;

          const originalChildrenById = new Map();
          original.querySelectorAll("*").forEach((child) => {
            if (child.id) originalChildrenById.set(child.id, child);
          });

          const originalChildren = Array.from(original.querySelectorAll("*"));
          cloned.querySelectorAll("*").forEach((clonedChild, index) => {
            const originalChild =
              (clonedChild.id && originalChildrenById.get(clonedChild.id)) ||
              originalChildren[index];
            if (!originalChild) return;
            const childStyle = String(
              originalChild.style.cssText ||
                originalChild.dataset.mlWrapperStyle ||
                originalChild.dataset.mlInnerStyle ||
                "",
            ).trim();
            if (childStyle) {
              clonedChild.style.cssText = childStyle;
            } else {
              const positioningStyle = extractPositioningStyles(
                String(
                  originalChild.dataset.mlWrapperStyle ||
                    originalChild.dataset.mlInnerStyle ||
                    originalChild.style.cssText ||
                    "",
                ),
              );
              if (positioningStyle) {
                clonedChild.style.cssText = positioningStyle;
              }
            }
          });
        };

        clone.querySelectorAll(".canvas-element").forEach((el) => {
          const original = canvas.querySelector(`#${el.id}`);
          if (original) {
            preserveElementStyles(el, original);
          }
        });

        clone.querySelectorAll(":scope > .canvas-element").forEach((el) => {
          if (el.classList.contains("in-layout-flow")) {
            el.classList.remove("in-layout-flow");
