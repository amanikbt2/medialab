      function ensureAdminAccess() {
        const unlocked =
          localStorage.getItem(ADMIN_ACCESS_KEY) === "granted" &&
          String(localStorage.getItem(ADMIN_EMAIL_KEY) || "").trim().toLowerCase() === ADMIN_EMAIL &&
          String(localStorage.getItem(ADMIN_PASSWORD_KEY) || "").trim() === ADMIN_PASSWORD;
        if (!unlocked) {
          localStorage.removeItem(ADMIN_ACCESS_KEY);
          localStorage.removeItem(ADMIN_EMAIL_KEY);
          localStorage.removeItem(ADMIN_PASSWORD_KEY);
